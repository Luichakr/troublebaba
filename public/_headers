# Cloudflare Pages headers — applied per-route in addition to defaults.
# Docs: https://developers.cloudflare.com/pages/configuration/headers/

# Hashed assets generated by Astro (filename includes content hash) — cache forever
/_astro/*
  Cache-Control: public, max-age=31536000, immutable

# Static images — long cache, allow revalidation
/images/*
  Cache-Control: public, max-age=2592000

# Favicons / manifest
/favicon.svg
  Cache-Control: public, max-age=604800
/favicon.ico
  Cache-Control: public, max-age=604800
/apple-touch-icon.png
  Cache-Control: public, max-age=604800
/site.webmanifest
  Cache-Control: public, max-age=604800

# HTML pages — short cache so content updates propagate fast
/*.html
  Cache-Control: public, max-age=300, must-revalidate
/
  Cache-Control: public, max-age=300, must-revalidate

# Security headers (apply to everything)
/*
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: camera=(), microphone=(), geolocation=()
  X-Frame-Options: SAMEORIGIN
  # HSTS — 1 year, includeSubDomains. NOT submitting to Chrome preload list
  # (preload registration is effectively irreversible).
  Strict-Transport-Security: max-age=31536000; includeSubDomains
  # Minimal CSP — self + GA4. Adjust if you add Gumroad iframe or other 3rd party.
  Content-Security-Policy: default-src 'self'; script-src 'self' 'unsafe-inline' https://www.googletagmanager.com https://www.google-analytics.com; img-src 'self' data: https:; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' data: https://fonts.gstatic.com; connect-src 'self' https://www.google-analytics.com https://*.google-analytics.com; frame-ancestors 'self'
