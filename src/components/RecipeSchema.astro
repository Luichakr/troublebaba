---
// Reusable Recipe JSON-LD component (schema.org/Recipe).
// Use on FREE recipe pages / blog recipe posts ONLY — pages that actually
// publish the full recipe (ingredients + steps). Do NOT use on the paid
// flavor-preview pages (they intentionally omit the recipe).
//
// Google requires recipeIngredient + recipeInstructions to be present and to
// MATCH the visible content — never emit Recipe schema for content the user
// can't see, or it's a structured-data policy violation.
//
// aggregateRating is OPTIONAL and must ONLY be passed once REAL reviews exist.
import { SITE } from '../config/site.js';

interface Instruction { text: string; name?: string; image?: string; }
interface Props {
  name: string;
  description: string;
  lang: string;
  image: string | string[];            // absolute or site-relative; normalised below
  recipeIngredient: string[];          // ["115 г муки", ...]
  recipeInstructions: (string | Instruction)[];
  prepTime?: string;                   // ISO 8601 duration, e.g. "PT30M"
  cookTime?: string;
  totalTime?: string;
  recipeYield?: string;                // "1 бенто-торт"
  recipeCategory?: string;             // "Dessert"
  recipeCuisine?: string;              // "European"
  keywords?: string;                   // comma-separated
  datePublished?: string;
  authorName?: string;
  authorUrl?: string;
  /** Pass ONLY when real, verifiable reviews exist. { ratingValue, reviewCount } */
  aggregateRating?: { ratingValue: number; reviewCount: number };
  /** YouTube/TikTok video object (optional, boosts video-rich-results). */
  video?: { name: string; description: string; thumbnailUrl: string; contentUrl?: string; embedUrl?: string; uploadDate?: string };
}

const {
  name, description, lang, image, recipeIngredient, recipeInstructions,
  prepTime, cookTime, totalTime, recipeYield,
  recipeCategory = 'Dessert', recipeCuisine = 'European', keywords,
  datePublished, authorName = 'TROUBLEBABA', authorUrl,
  aggregateRating, video,
} = Astro.props;

const SITE_URL = SITE.url.replace(/\/$/, '');
const abs = (u: string) => (u.startsWith('http') ? u : SITE_URL + '/' + u.replace(/^\/+/, ''));
const images = (Array.isArray(image) ? image : [image]).map(abs);

const schema: Record<string, unknown> = {
  '@context': 'https://schema.org',
  '@type': 'Recipe',
  name,
  description,
  inLanguage: lang,
  image: images,
  recipeIngredient,
  recipeInstructions: recipeInstructions.map((step) =>
    typeof step === 'string'
      ? { '@type': 'HowToStep', text: step }
      : { '@type': 'HowToStep', text: step.text, ...(step.name ? { name: step.name } : {}), ...(step.image ? { image: abs(step.image) } : {}) },
  ),
  recipeCategory,
  recipeCuisine,
  author: { '@type': 'Person', name: authorName, url: authorUrl ?? SITE_URL + '/about' },
  publisher: { '@type': 'Organization', name: SITE.name, logo: SITE_URL + '/favicon.svg' },
};

if (prepTime)  schema.prepTime  = prepTime;
if (cookTime)  schema.cookTime  = cookTime;
if (totalTime) schema.totalTime = totalTime;
if (recipeYield) schema.recipeYield = recipeYield;
if (keywords) schema.keywords = keywords;
if (datePublished) schema.datePublished = datePublished;
if (aggregateRating) {
  schema.aggregateRating = {
    '@type': 'AggregateRating',
    ratingValue: aggregateRating.ratingValue,
    reviewCount: aggregateRating.reviewCount,
  };
}
if (video) {
  schema.video = {
    '@type': 'VideoObject',
    name: video.name,
    description: video.description,
    thumbnailUrl: abs(video.thumbnailUrl),
    ...(video.contentUrl ? { contentUrl: video.contentUrl } : {}),
    ...(video.embedUrl ? { embedUrl: video.embedUrl } : {}),
    ...(video.uploadDate ? { uploadDate: video.uploadDate } : {}),
  };
}
---
<script type="application/ld+json" set:html={JSON.stringify(schema)} />
