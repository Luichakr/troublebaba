---
import { t } from '../i18n/translations.js';
import { SITE } from '../config/site.js';

type Lang = 'uk' | 'ru' | 'pl' | 'en';
interface Props { lang: Lang; homeUrl: string }
const { lang, homeUrl } = Astro.props;
const tr = (t as any)[lang] as Record<string, any>;

const socials = [
  { label: 'Instagram', url: SITE.instagramUrl },
  { label: 'TikTok',    url: SITE.tiktokUrl },
  { label: 'YouTube',   url: SITE.youtubeUrl },
  { label: 'Facebook',  url: SITE.facebookUrl },
];
---
<main class="min-h-[100dvh] py-16 lg:py-24" style="background:#F5EFE8;">
  <div class="max-w-2xl mx-auto px-6 lg:px-10">

    <a href={homeUrl} class="inline-flex items-center gap-2 font-outfit text-mocha hover:text-mocha-dark transition-colors text-sm mb-10">
      <svg width="14" height="12" viewBox="0 0 16 14" fill="none" aria-hidden="true"><path d="M14 7H2M7 2L2 7l5 5" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>
      <span>{tr.contact_back}</span>
    </a>

    <h1 class="font-cabinet text-espresso mb-4" style="font-size:clamp(2rem,4vw,3rem);line-height:1.1;">{tr.contact_heading}</h1>
    <p class="font-outfit text-espresso/65 text-base leading-relaxed mb-10">{tr.contact_intro}</p>

    <!-- Email card -->
    <div class="bg-warm-white rounded-2xl p-6 mb-4" style="box-shadow:0 4px 18px rgba(139,115,85,0.10);">
      <div class="font-outfit text-[11px] font-bold uppercase tracking-[0.16em] text-mocha mb-2">{tr.contact_email_label}</div>
      <a href={`mailto:${SITE.contactEmail}`} class="font-cabinet text-espresso text-xl hover:text-mocha transition-colors">{SITE.contactEmail}</a>
    </div>

    <!-- Socials card -->
    <div class="bg-warm-white rounded-2xl p-6 mb-8" style="box-shadow:0 4px 18px rgba(139,115,85,0.10);">
      <div class="font-outfit text-[11px] font-bold uppercase tracking-[0.16em] text-mocha mb-3">{tr.contact_social_label}</div>
      <div class="flex flex-wrap gap-2.5">
        {socials.map(s => (
          <a href={s.url} target="_blank" rel="noopener noreferrer"
             class="font-outfit text-sm text-espresso/75 bg-surface border border-taupe/30 hover:border-mocha/50 transition-colors rounded-full px-4 py-2.5 min-h-[44px] inline-flex items-center">{s.label}</a>
        ))}
      </div>
    </div>

    <p class="font-outfit text-espresso/50 text-sm leading-relaxed">{tr.contact_response}</p>
  </div>
</main>
