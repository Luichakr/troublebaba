---
import { getCollection } from 'astro:content';
import { t } from '../i18n/translations.js';
import { SITE } from '../config/site.js';

type Lang = 'uk' | 'ru' | 'pl' | 'en';
interface Props { lang: Lang; homeUrl: string }
const { lang, homeUrl } = Astro.props;
const tr = (t as any)[lang] as Record<string, any>;

const all = await getCollection('blog', (e: any) => e.data.lang === lang && e.data.draft === false);
all.sort((a: any, b: any) => (a.data.publishedAt < b.data.publishedAt ? 1 : -1));
const langPrefix = lang === 'uk' ? '' : '/' + lang;
const postUrl = (slug: string) => `${langPrefix}/blog/${slug}/`;
---
<main class="min-h-[100dvh]" style="background:#F5EFE8;">
  <div class="max-w-[1100px] mx-auto px-6 lg:px-16 py-12 lg:py-20">

    <a href={homeUrl} class="inline-flex items-center gap-2 font-outfit text-mocha hover:text-mocha-dark transition-colors text-sm mb-10">
      <svg width="14" height="12" viewBox="0 0 16 14" fill="none" aria-hidden="true"><path d="M14 7H2M7 2L2 7l5 5" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>
      <span>{tr.blog_back}</span>
    </a>

    <header class="max-w-[640px] mb-10">
      <h1 class="font-cabinet text-espresso mb-5" style="font-size:clamp(2.4rem,5vw,4rem);line-height:1.02;">{tr.blog_heading}</h1>
      <p class="font-outfit text-espresso/60 text-base leading-relaxed">{tr.blog_intro}</p>
    </header>

    {/* Видеорецепты — funnel from blog hub to /shorts/ archive */}
    <a href={`${langPrefix}/shorts/`}
       data-analytics="blog_videos_promo_click" data-platform="shorts"
       class="group block mb-12 rounded-2xl bg-warm-white overflow-hidden hover:-translate-y-0.5 transition-transform duration-300"
       style="box-shadow:0 8px 32px rgba(139,115,85,0.10), 0 24px 64px rgba(139,115,85,0.06); border:1px solid rgba(200,184,162,0.30);">
      <div class="grid sm:grid-cols-[minmax(0,1fr)_minmax(0,1fr)] items-stretch">
        <div class="px-6 sm:px-8 lg:px-10 py-8 lg:py-10 flex flex-col justify-center">
          <div class="flex items-center gap-3 mb-3">
            <span class="inline-block w-2 h-2 rounded-full" style="background:#B85959; box-shadow:0 0 0 4px rgba(184,89,89,0.18);"></span>
            <span class="font-outfit text-[11px] font-bold uppercase tracking-[0.22em] text-mocha">{tr.blog_videos_eyebrow}</span>
          </div>
          <h2 class="font-cabinet text-espresso mb-3 group-hover:text-mocha transition-colors" style="font-size:clamp(1.4rem,2.4vw,1.9rem);line-height:1.1;">{tr.blog_videos_title}</h2>
          <p class="font-outfit text-espresso/65 text-[14px] leading-relaxed mb-5 max-w-[420px]">{tr.blog_videos_sub}</p>
          <span class="inline-flex items-center gap-2 font-outfit text-mocha font-semibold text-sm">
            <span>{tr.blog_videos_cta}</span>
            <svg width="14" height="12" viewBox="0 0 16 14" fill="none" aria-hidden="true"><path d="M2 7h12M10 2l5 5-5 5" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </span>
        </div>
        <div class="px-6 sm:px-8 lg:pr-10 pb-8 pt-2 sm:pl-0 sm:py-8 lg:py-10">
          <div class="grid grid-cols-4 gap-2.5" data-blog-videos-tiles>
            {Array.from({length: 4}).map(() => (
              <div class="rounded-md bg-espresso/5" style="aspect-ratio:9/16;"></div>
            ))}
          </div>
        </div>
      </div>
    </a>

    {/* Instagram + TikTok recipe blocks — mirror the video block, link to profiles */}
    <div class="grid sm:grid-cols-2 gap-5 mb-8">
      <a href={SITE.instagramUrl} target="_blank" rel="noopener noreferrer"
         data-analytics="blog_platform_block" data-platform="instagram"
         class="group block rounded-2xl bg-warm-white overflow-hidden hover:-translate-y-0.5 transition-transform duration-300"
         style="box-shadow:0 8px 32px rgba(139,115,85,0.10); border:1px solid rgba(200,184,162,0.30);">
        <div class="grid grid-cols-[minmax(0,1fr)_minmax(0,150px)] items-stretch">
          <div class="px-6 py-7 flex flex-col justify-center">
            <div class="flex items-center gap-2 mb-3">
              <span class="w-6 h-6 rounded-md flex items-center justify-center" style="background:linear-gradient(135deg,#f09433,#dc2743,#bc1888);"><svg width="13" height="13" viewBox="0 0 24 24" fill="none"><rect x="2" y="2" width="20" height="20" rx="6" stroke="white" stroke-width="2"/><circle cx="12" cy="12" r="4.5" stroke="white" stroke-width="2"/><circle cx="17.5" cy="6.5" r="1.2" fill="white"/></svg></span>
              <span class="font-outfit text-[11px] font-bold uppercase tracking-[0.18em] text-mocha">Instagram</span>
            </div>
            <h2 class="font-cabinet text-espresso mb-2 group-hover:text-mocha transition-colors" style="font-size:clamp(1.2rem,2vw,1.5rem);line-height:1.12;">{tr.blog_ig_title}</h2>
            <p class="font-outfit text-espresso/60 text-[13px] leading-relaxed mb-4">{tr.blog_ig_sub}</p>
            <span class="inline-flex items-center gap-2 font-outfit text-mocha font-semibold text-[13px]">
              <span>{tr.blog_ig_cta}</span>
              <svg width="13" height="11" viewBox="0 0 16 14" fill="none" aria-hidden="true"><path d="M2 7h12M10 2l5 5-5 5" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </span>
          </div>
          <div class="relative overflow-hidden">
            <img src="/images/social/instagram-bento-cover.webp" alt={tr.blog_ig_title} width="300" height="375" loading="lazy" decoding="async" class="absolute inset-0 w-full h-full object-cover group-hover:scale-[1.05] transition-transform duration-500" />
          </div>
        </div>
      </a>

      <a href={SITE.tiktokUrl} target="_blank" rel="noopener noreferrer"
         data-analytics="blog_platform_block" data-platform="tiktok"
         class="group block rounded-2xl bg-warm-white overflow-hidden hover:-translate-y-0.5 transition-transform duration-300"
         style="box-shadow:0 8px 32px rgba(139,115,85,0.10); border:1px solid rgba(200,184,162,0.30);">
        <div class="grid grid-cols-[minmax(0,1fr)_minmax(0,150px)] items-stretch">
          <div class="px-6 py-7 flex flex-col justify-center">
            <div class="flex items-center gap-2 mb-3">
              <span class="w-6 h-6 rounded-md flex items-center justify-center" style="background:#000;"><svg width="11" height="13" viewBox="0 0 24 26" fill="none"><path d="M17 1C17.3 4.5 19.3 6.8 23 7.1V11C21 10.8 19.2 10.1 17.7 9V17.5C17.7 21.9 14.4 25.5 10 25.5C5.6 25.5 2 22 2 17.6C2 13.1 5.5 9.8 10 9.8C10.4 9.8 10.7 9.8 11 9.9V14C10.7 13.9 10.4 13.9 10 13.9C7.8 13.9 6 15.6 6 17.8C6 20 7.8 21.6 10 21.6C12.2 21.6 14.1 19.9 14.1 17.7L14.2 1H17Z" fill="white"/></svg></span>
              <span class="font-outfit text-[11px] font-bold uppercase tracking-[0.18em] text-mocha">TikTok</span>
            </div>
            <h2 class="font-cabinet text-espresso mb-2 group-hover:text-mocha transition-colors" style="font-size:clamp(1.2rem,2vw,1.5rem);line-height:1.12;">{tr.blog_tt_title}</h2>
            <p class="font-outfit text-espresso/60 text-[13px] leading-relaxed mb-4">{tr.blog_tt_sub}</p>
            <span class="inline-flex items-center gap-2 font-outfit text-mocha font-semibold text-[13px]">
              <span>{tr.blog_tt_cta}</span>
              <svg width="13" height="11" viewBox="0 0 16 14" fill="none" aria-hidden="true"><path d="M2 7h12M10 2l5 5-5 5" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </span>
          </div>
          <div class="relative overflow-hidden">
            <img src="/images/social/tiktok-bento-cover.webp" alt={tr.blog_tt_title} width="300" height="375" loading="lazy" decoding="async" class="absolute inset-0 w-full h-full object-cover group-hover:scale-[1.05] transition-transform duration-500" />
          </div>
        </div>
      </a>
    </div>

    {/* Follow on social — blog → social funnel */}
    <div class="flex flex-wrap items-center gap-3 mb-12">
      <span class="font-outfit text-espresso/60 text-sm font-medium mr-1">{tr.blog_social_follow}</span>
      <a href={SITE.instagramUrl} target="_blank" rel="noopener noreferrer"
         data-analytics="blog_social_click" data-platform="instagram"
         class="inline-flex items-center gap-2 bg-warm-white border border-taupe/30 hover:border-mocha/50 transition-colors rounded-full px-4 py-2.5 text-espresso/75 font-outfit text-sm font-medium min-h-[44px]">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" aria-hidden="true"><rect x="2" y="2" width="20" height="20" rx="6" stroke="#8B7355" stroke-width="1.6"/><circle cx="12" cy="12" r="4.5" stroke="#8B7355" stroke-width="1.6"/><circle cx="17.5" cy="6.5" r="1.2" fill="#8B7355"/></svg>
        <span>{tr.social_pill_ig}</span>
      </a>
      <a href={SITE.tiktokUrl} target="_blank" rel="noopener noreferrer"
         data-analytics="blog_social_click" data-platform="tiktok"
         class="inline-flex items-center gap-2 bg-warm-white border border-taupe/30 hover:border-mocha/50 transition-colors rounded-full px-4 py-2.5 text-espresso/75 font-outfit text-sm font-medium min-h-[44px]">
        <svg width="14" height="16" viewBox="0 0 24 26" fill="none" aria-hidden="true"><path d="M17 1C17.3 4.5 19.3 6.8 23 7.1V11C21 10.8 19.2 10.1 17.7 9V17.5C17.7 21.9 14.4 25.5 10 25.5C5.6 25.5 2 22 2 17.6C2 13.1 5.5 9.8 10 9.8C10.4 9.8 10.7 9.8 11 9.9V14C10.7 13.9 10.4 13.9 10 13.9C7.8 13.9 6 15.6 6 17.8C6 20 7.8 21.6 10 21.6C12.2 21.6 14.1 19.9 14.1 17.7L14.2 1H17Z" stroke="#8B7355" stroke-width="1.6" stroke-linejoin="round"/></svg>
        <span>{tr.social_pill_tt}</span>
      </a>
      <a href={SITE.youtubeUrl} target="_blank" rel="noopener noreferrer"
         data-analytics="blog_social_click" data-platform="youtube"
         class="inline-flex items-center gap-2 bg-warm-white border border-taupe/30 hover:border-mocha/50 transition-colors rounded-full px-4 py-2.5 text-espresso/75 font-outfit text-sm font-medium min-h-[44px]">
        <svg width="18" height="13" viewBox="0 0 28 20" fill="none" aria-hidden="true"><path d="M26.5 3.2C26.2 2.1 25.3 1.3 24.2 1C22.2 0.5 14 0.5 14 0.5C14 0.5 5.8 0.5 3.8 1C2.7 1.3 1.8 2.2 1.5 3.2C1 5.2 1 10 1 10C1 10 1 14.8 1.5 16.8C1.8 17.9 2.7 18.7 3.8 19C5.8 19.5 14 19.5 14 19.5C14 19.5 22.2 19.5 24.2 19C25.3 18.7 26.2 17.8 26.5 16.8C27 14.8 27 10 27 10C27 10 27 5.2 26.5 3.2Z" stroke="#8B7355" stroke-width="1.6"/><path d="M11.5 14L18 10L11.5 6V14Z" fill="#8B7355"/></svg>
        <span>{tr.social_pill_yt}</span>
      </a>
    </div>

    <script is:inline>
      (function () {
        const tiles = document.querySelector('[data-blog-videos-tiles]');
        if (!tiles) return;
        function escape(s) { return String(s).replace(/[&<>"']/g, c => ({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'}[c])); }
        fetch('/api/shorts/feed?all=1').then(r => r.ok ? r.json() : null).then(data => {
          if (!data || !data.ok) return;
          const items = [];
          if (data.current) items.push(data.current);
          (data.recent || []).forEach(s => items.push(s));
          if (!items.length) return;
          tiles.innerHTML = items.slice(0, 4).map(function (s) {
            return '<div class="relative rounded-md overflow-hidden bg-espresso/5" style="aspect-ratio:9/16;">' +
              '<img src="https://i.ytimg.com/vi/' + escape(s.videoId) + '/hqdefault.jpg" alt="' + escape(s.title) + '"' +
              ' width="200" height="356" loading="lazy" decoding="async"' +
              ' class="absolute inset-0 w-full h-full object-cover"/>' +
              '<span class="absolute inset-0 bg-gradient-to-t from-espresso/35 to-transparent"></span>' +
              '</div>';
          }).join('');
        }).catch(function () {});
      })();
    </script>

    {all.length === 0 ? (
      <p class="font-outfit text-espresso/45 italic py-10">{tr.blog_empty}</p>
    ) : (
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {all.map((post: any) => (
          <a href={postUrl(post.data.slug)} class="group block bg-warm-white rounded-2xl overflow-hidden" style="box-shadow:0 4px 18px rgba(139,115,85,0.10);">
            {post.data.cover && (
              <div class="relative overflow-hidden" style="aspect-ratio:16/10;">
                <img src={post.data.cover} alt={post.data.title} loading="lazy" decoding="async" class="absolute inset-0 w-full h-full object-cover group-hover:scale-[1.04] transition-transform duration-500" onerror="this.style.display='none'" />
              </div>
            )}
            <div class="p-5">
              <h2 class="font-cabinet text-espresso text-lg mb-2 leading-snug group-hover:text-mocha transition-colors">{post.data.title}</h2>
              <p class="font-outfit text-espresso/55 text-[13px] leading-relaxed">{post.data.excerpt ?? post.data.description}</p>
            </div>
          </a>
        ))}
      </div>
    )}
  </div>
</main>
