---
// Free recipe lead-magnet landing.
//
// Hero with copy, a benefits list, an email form that POSTs to /api/free-recipe,
// and a soft "see full collection" CTA. After successful submit the form is
// replaced with a thank-you state. Designed to live at /free-recipe/ and per-
// language routes; reusable from anywhere via <FreeRecipe lang="…"/>.
//
// The actual recipe content (which of the 10 tortes is given away) is the
// author's call — that lives in copy outside this component once decided.

import { t } from '../i18n/translations.js';
import { SITE } from '../config/site.js';

interface Props { lang: 'uk' | 'ru' | 'pl' | 'en' }
const { lang } = Astro.props;
const tr = (t as any)[lang];
const langPrefix = lang === 'uk' ? '' : '/' + lang;
const recipesHref = langPrefix + '/recipes/';
const homeHref    = langPrefix + '/';
const successText = (tr.fr_success_text as string).replace('{EMAIL}', SITE.contactEmail);
const turnstileKey = SITE.turnstile?.siteKey || '';
---

<section class="min-h-[100dvh] py-14 lg:py-20" style="background:#F5EFE8;">
  <div class="max-w-[1440px] mx-auto px-4 sm:px-6 lg:px-10">

    <!-- Back to home -->
    <a href={homeHref}
       class="inline-flex items-center gap-2 font-outfit text-mocha hover:text-mocha-dark transition-colors text-sm mb-10">
      <svg width="14" height="12" viewBox="0 0 16 14" fill="none" aria-hidden="true">
        <path d="M14 7H2M7 2L2 7l5 5" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
      <span>TROUBLEBABA</span>
    </a>

    <!-- Hero + form, asymmetric split -->
    <div class="grid lg:grid-cols-[minmax(0,1fr)_minmax(0,420px)] gap-10 lg:gap-16 items-start">

      <!-- Left: copy + what's inside -->
      <div>
        <div class="flex items-center gap-3 mb-5">
          <span class="inline-block w-2 h-2 rounded-full" style="background:#B85959; box-shadow:0 0 0 4px rgba(184,89,89,0.18);"></span>
          <span class="font-outfit text-[11px] font-bold uppercase tracking-[0.22em] text-mocha">{tr.fr_eyebrow}</span>
        </div>
        <h1 class="font-cabinet text-espresso mb-5" style="font-size:clamp(2.2rem,4.4vw,3.6rem);line-height:1.04;">{tr.fr_title}</h1>
        <p class="font-outfit text-espresso/70 text-[16px] lg:text-[17px] leading-relaxed max-w-[580px] mb-10">{tr.fr_sub}</p>

        <!-- What's inside -->
        <div class="rounded-2xl bg-warm-white p-6 lg:p-8 max-w-[580px]"
             style="box-shadow:0 4px 18px rgba(139,115,85,0.08); border:1px solid rgba(200,184,162,0.25);">
          <div class="font-outfit text-[11px] font-bold uppercase tracking-[0.18em] text-espresso/45 mb-4">{tr.fr_inside_title}</div>
          <ul class="space-y-3">
            {(tr.fr_inside as string[]).map((item) => (
              <li class="flex items-start gap-3 font-outfit text-espresso/80 text-[15px] leading-snug">
                <svg width="18" height="18" viewBox="0 0 20 20" fill="none" class="flex-shrink-0 mt-0.5" aria-hidden="true">
                  <circle cx="10" cy="10" r="9" stroke="#8B7355" stroke-width="1.5"/>
                  <path d="M6 10.5L9 13.5L14 7.5" stroke="#8B7355" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
                <span>{item}</span>
              </li>
            ))}
          </ul>
        </div>
      </div>

      <!-- Right: email form card -->
      <aside class="lg:sticky lg:top-8 self-start w-full">
        <div class="rounded-2xl bg-warm-white p-7 lg:p-9"
             style="box-shadow:0 12px 40px rgba(139,115,85,0.12), 0 32px 80px rgba(139,115,85,0.06); border:1px solid rgba(200,184,162,0.30);">

          <form data-free-recipe-form class="space-y-4" novalidate>
            <label class="block">
              <span class="font-outfit text-[12px] font-semibold uppercase tracking-wide text-espresso/55 mb-2 block">{tr.fr_email_label}</span>
              <input type="email" name="email" required autocomplete="email"
                     placeholder={tr.fr_email_ph}
                     class="w-full bg-surface border border-taupe/40 focus:border-mocha rounded-xl px-4 py-3.5 font-outfit text-espresso text-[15px] min-h-[48px] outline-none transition-colors"/>
            </label>

            {turnstileKey && <div class="cf-turnstile" data-sitekey={turnstileKey}></div>}

            <button type="submit"
                    data-analytics="free_recipe_submit" data-lang={lang}
                    class="w-full inline-flex items-center justify-center gap-2 bg-mocha hover:bg-mocha-dark text-warm-white transition-colors font-outfit font-bold rounded-xl px-6 py-4 text-[15px] min-h-[52px]">
              <span data-fr-btn-label>{tr.fr_btn_get}</span>
              <svg width="16" height="14" viewBox="0 0 16 14" fill="none" aria-hidden="true">
                <path d="M2 7h12M10 2l5 5-5 5" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </button>

            <p class="font-outfit text-espresso/50 text-xs leading-relaxed">{tr.fr_consent}</p>
          </form>

          <!-- Success state (hidden until form submits OK) -->
          <div data-free-recipe-success hidden>
            <div class="flex items-center gap-3 mb-4">
              <svg width="36" height="36" viewBox="0 0 40 40" fill="none" aria-hidden="true">
                <circle cx="20" cy="20" r="19" stroke="#8B7355" stroke-width="1.5" fill="#F5EFE8"/>
                <path d="M12 21l5 5L29 14" stroke="#8B7355" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
              <h2 class="font-cabinet text-espresso text-xl">{tr.fr_success_title}</h2>
            </div>
            <p class="font-outfit text-espresso/70 text-[15px] leading-relaxed whitespace-pre-line">{successText}</p>
          </div>
        </div>
      </aside>
    </div>

    <!-- Soft cross-sell after form -->
    <div class="mt-16 lg:mt-24 rounded-2xl bg-warm-white p-7 lg:p-10 max-w-[860px] mx-auto text-center"
         style="box-shadow:0 4px 18px rgba(139,115,85,0.10); border:1px solid rgba(200,184,162,0.30);">
      <h2 class="font-cabinet text-espresso mb-5" style="font-size:clamp(1.4rem,2.4vw,2rem);line-height:1.15;">{tr.fr_cta_title}</h2>
      <a href={recipesHref}
         data-analytics="free_recipe_to_recipes"
         class="inline-flex items-center gap-2 bg-mocha hover:bg-mocha-dark text-warm-white transition-colors font-outfit font-semibold rounded-xl px-6 py-3.5 text-[14px] min-h-[48px]">
        <span>{tr.fr_cta_btn}</span>
        <svg width="14" height="12" viewBox="0 0 16 14" fill="none" aria-hidden="true">
          <path d="M2 7h12M10 2l5 5-5 5" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </a>
    </div>
  </div>

  {turnstileKey && <script src="https://challenges.cloudflare.com/turnstile/v0/api.js" async defer is:inline></script>}
  <script is:inline define:vars={{ lang, busyLabel: tr.fr_btn_sending, defaultLabel: tr.fr_btn_get, turnstileKey }}>
    (function () {
      const form    = document.querySelector('[data-free-recipe-form]');
      const success = document.querySelector('[data-free-recipe-success]');
      if (!form || !success) return;
      const btn      = form.querySelector('button[type="submit"]');
      const btnLabel = form.querySelector('[data-fr-btn-label]');
      const input    = form.querySelector('input[name="email"]');

      form.addEventListener('submit', async function (e) {
        e.preventDefault();
        if (!input || !input.value || !/^[^\s@]+@[^\s@]+\.[^\s@]{2,}$/.test(input.value)) {
          input?.focus();
          return;
        }
        const turnstileToken = (form.querySelector('[name="cf-turnstile-response"]') || {}).value || '';
        if (turnstileKey && !turnstileToken) { input?.focus(); return; }
        btn.disabled = true;
        if (btnLabel) btnLabel.textContent = busyLabel;

        try {
          const r = await fetch('/api/free-recipe', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ email: input.value.trim(), lang, source: 'free_recipe_page', turnstileToken }),
          });
          const data = await r.json().catch(function () { return { ok: false }; });
          if (r.ok && data && data.ok) {
            form.style.display = 'none';
            success.removeAttribute('hidden');
            if (typeof gtag === 'function') gtag('event', 'free_recipe_lead', { lang });
          } else {
            // Inline error — keep form open
            btn.disabled = false;
            if (btnLabel) btnLabel.textContent = defaultLabel;
            input.focus();
          }
        } catch {
          btn.disabled = false;
          if (btnLabel) btnLabel.textContent = defaultLabel;
        }
      });
    })();
  </script>
</section>
