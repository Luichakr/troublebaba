<script>
import { BONUS_TOTAL, BONUS_REMAINING } from '../i18n/translations.js';

function attachFaqListeners() {
  const toggle = (item: Element) => {
    const wasOpen = item.classList.contains('open');
    document.querySelectorAll('.faq-item').forEach(i => {
      i.classList.remove('open');
      i.setAttribute('aria-expanded', 'false');
    });
    if (!wasOpen) {
      item.classList.add('open');
      item.setAttribute('aria-expanded', 'true');
    }
  };
  document.querySelectorAll('.faq-item').forEach(item => {
    item.addEventListener('click', () => toggle(item));
    item.addEventListener('keydown', (e) => {
      const key = (e as KeyboardEvent).key;
      if (key === 'Enter' || key === ' ') {
        e.preventDefault();
        toggle(item);
      }
    });
  });
}

// Scroll reveal
const observer = new IntersectionObserver(entries => {
  entries.forEach(el => {
    if (el.isIntersecting) {
      el.target.classList.add('visible');
      observer.unobserve(el.target);
    }
  });
}, { threshold: 0.1 });
document.querySelectorAll('.reveal').forEach(el => observer.observe(el));

// FAQ accordion
attachFaqListeners();

// ── Bonus counter: animate 20 → BONUS_REMAINING on viewport enter ──
(() => {
  const counterEl = document.getElementById('bonus-counter');
  if (!counterEl) return;

  const numEl     = document.getElementById('bonus-counter-num');
  const barEl     = document.getElementById('bonus-counter-bar') as HTMLElement | null;
  const takenEl   = document.getElementById('bonus-counter-taken');
  const soldBadge = document.getElementById('bonus-soldout-badge');
  const ctaBtn    = document.getElementById('bonus-cta-btn') as HTMLElement | null;
  const isSoldOut = BONUS_REMAINING <= 0;

  if (isSoldOut) {
    counterEl.style.opacity = '0.6';
    counterEl.style.filter  = 'grayscale(0.4)';
    if (soldBadge) soldBadge.classList.remove('hidden');
    if (ctaBtn) {
      ctaBtn.style.opacity = '0.55';
      ctaBtn.style.pointerEvents = 'none';
      ctaBtn.classList.remove('btn-pulse');
    }
  }

  const target = Math.max(0, BONUS_REMAINING);

  const animate = () => {
    const duration = 1800;
    const startTime = performance.now();
    const tick = (now: number) => {
      const p = Math.min(1, (now - startTime) / duration);
      const eased = 1 - Math.pow(1 - p, 3);
      const cur = Math.round(BONUS_TOTAL - (BONUS_TOTAL - target) * eased);
      const takenCur = BONUS_TOTAL - cur;
      if (numEl) numEl.textContent = String(cur);
      if (takenEl) takenEl.textContent = String(takenCur);
      if (barEl) barEl.style.width = (cur / BONUS_TOTAL * 100) + '%';
      if (p < 1) requestAnimationFrame(tick);
    };
    requestAnimationFrame(tick);
  };

  if (numEl) numEl.textContent = String(BONUS_TOTAL);
  if (takenEl) takenEl.textContent = '0';
  if (barEl) barEl.style.width = '100%';

  const bonusObs = new IntersectionObserver(entries => {
    entries.forEach(e => {
      if (e.isIntersecting) {
        animate();
        bonusObs.unobserve(e.target);
      }
    });
  }, { threshold: 0.3 });
  bonusObs.observe(counterEl);
})();

// Sticky CTA — show after scroll past hero on mobile
const stickyCta = document.getElementById('sticky-cta');
if (stickyCta) {
  const showAfter = window.innerHeight * 0.8;
  const onScroll = () => {
    if (window.scrollY > showAfter) {
      stickyCta.classList.remove('opacity-0', 'pointer-events-none', 'translate-y-4');
    } else {
      stickyCta.classList.add('opacity-0', 'pointer-events-none', 'translate-y-4');
    }
  };
  window.addEventListener('scroll', onScroll, { passive: true });
  onScroll();
}

// Mobile menu toggle
const mobMenuBtn = document.getElementById('mobile-menu-btn');
const mobMenu = document.getElementById('mobile-menu');
const setMobOpen = (open: boolean) => {
  mobMenu?.classList.toggle('hidden', !open);
  mobMenuBtn?.setAttribute('aria-expanded', String(open));
};
if (mobMenuBtn && mobMenu) {
  mobMenuBtn.addEventListener('click', (e) => {
    e.stopPropagation();
    setMobOpen(mobMenu.classList.contains('hidden'));
  });
  document.querySelectorAll('.mobile-menu-link').forEach(link => {
    link.addEventListener('click', () => setMobOpen(false));
  });
  document.addEventListener('click', (e) => {
    if (!mobMenu.contains(e.target as Node) && !mobMenuBtn.contains(e.target as Node)) {
      setMobOpen(false);
    }
  });
}

// Lang dropdown toggle (items are now anchor links)
const dropBtn = document.getElementById('lang-dropdown-btn');
const dropMenu = document.getElementById('lang-menu');
const dropChevron = document.getElementById('lang-chevron');
const setDropOpen = (open: boolean) => {
  dropMenu?.classList.toggle('hidden', !open);
  dropBtn?.setAttribute('aria-expanded', String(open));
  dropChevron?.style.setProperty('transform', open ? 'rotate(180deg)' : '');
};
if (dropBtn && dropMenu) {
  dropBtn.addEventListener('click', (e) => {
    e.stopPropagation();
    setDropOpen(dropMenu.classList.contains('hidden'));
  });
  document.addEventListener('click', () => setDropOpen(false));
}

// ESC closes mobile menu and lang dropdown
document.addEventListener('keydown', (e) => {
  if (e.key !== 'Escape') return;
  setMobOpen(false);
  setDropOpen(false);
});

// ── GA4 events: track buy clicks + FAQ opens + language clicks ──
type GtagFn = (event: 'event', name: string, params?: Record<string, unknown>) => void;
const gtag = (window as unknown as { gtag?: GtagFn }).gtag;
const send = (name: string, params: Record<string, unknown> = {}) => {
  if (typeof gtag === 'function') gtag('event', name, params);
};

document.querySelectorAll<HTMLAnchorElement>('[data-buy-source]').forEach(a => {
  a.addEventListener('click', () => {
    send('click_buy', {
      source: a.dataset.buySource,
      page_lang: document.documentElement.lang || 'uk',
    });
  });
});

document.querySelectorAll<HTMLAnchorElement>('.lang-btn').forEach(a => {
  a.addEventListener('click', () => {
    send('language_switch', {
      target_lang: a.getAttribute('href') || '',
      from_lang: document.documentElement.lang || 'uk',
    });
  });
});

// FAQ open tracking — fire when a closed item becomes open
document.querySelectorAll<HTMLElement>('.faq-item').forEach(item => {
  item.addEventListener('click', () => {
    if (item.classList.contains('open')) {
      send('faq_open', {
        index: item.dataset.index || '',
        page_lang: document.documentElement.lang || 'uk',
      });
    }
  });
});
</script>
