---
import { t } from '../i18n/translations.js';
import { SITE } from '../config/site.js';

type Lang = 'uk' | 'ru' | 'pl' | 'en';
interface Props { lang: Lang }
const { lang } = Astro.props;
const tr = t[lang] as Record<string, any>;

// Helpers
const isUk = lang === 'uk';
const langUrl = (l: Lang) => l === 'uk' ? '/' : `/${l}/`;

const RECIPE_IMAGES = [
  'images/q9.webp',   // 0: Oreo
  'images/q5.webp',   // 1: Red Velvet
  'images/q3.webp',   // 2: Poppy-Citrus
  'images/q6.webp',   // 3: Snickers
  'images/q1.webp',   // 4: Raffaello
  'images/q7.webp',   // 5: Ferrero Rocher
  'images/q8.webp',   // 6: Cinnabon
  'images/q2.webp',   // 7: Pistachio-Raspberry
  'images/q10.webp',  // 8: Pina Colada
  'images/q4.webp',   // 9: Cherry Chocolate
];

const LANGS: { c: Lang; l: string; full: string }[] = [
  { c: 'uk', l: 'UKR', full: 'Українська' },
  { c: 'ru', l: 'RUS', full: 'Русский' },
  { c: 'pl', l: 'POL', full: 'Polski' },
  { c: 'en', l: 'ENG', full: 'English' },
];
const currentLangLabel = LANGS.find(x => x.c === lang)?.l ?? 'UKR';
---

  <!-- ── HEADER ── -->
  <header class="fixed top-0 left-0 right-0 z-50 bg-cream/95 backdrop-blur-md border-b border-taupe/15">
    <div class="max-w-[1440px] mx-auto px-4 lg:px-16 h-[68px] lg:h-[72px] flex items-center justify-between gap-2 lg:gap-6">
      <a href={langUrl(lang)} class="font-cabinet text-espresso flex-shrink-0 text-[1.1rem] lg:text-[1.55rem]" style="letter-spacing:0.01em;">TROUBLEBABA</a>
      <nav class="hidden md:flex items-center gap-10 font-outfit text-[12px] font-semibold tracking-[0.16em] uppercase text-espresso/65">
        <a href="#recipes" class="hover:text-espresso transition-colors">{tr.nav_recipes}</a>
        <a href="#about" class="hover:text-espresso transition-colors">{tr.nav_author}</a>
        <a href="#price" class="hover:text-espresso transition-colors">{tr.nav_price}</a>
        <a href="#faq" class="hover:text-espresso transition-colors">FAQ</a>
      </nav>
      <div class="flex items-center gap-3 flex-shrink-0">
        <!-- Language dropdown -->
        <div class="relative hidden sm:block" id="lang-dropdown-wrap">
          <button id="lang-dropdown-btn" type="button" aria-haspopup="listbox" aria-expanded="false" aria-controls="lang-menu" aria-label="Choose language" class="flex items-center gap-1.5 font-outfit font-semibold text-[12px] tracking-[0.12em] uppercase text-espresso/70 hover:text-espresso transition-colors px-4 py-2.5 rounded-full border border-taupe/40 hover:border-taupe/60">
            <span id="lang-label">{currentLangLabel}</span>
            <svg width="11" height="7" viewBox="0 0 12 8" fill="none" class="transition-transform duration-200" id="lang-chevron">
              <path d="M1 1.5L6 6.5L11 1.5" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </button>
          <div id="lang-menu" role="listbox" aria-label="Languages" class="hidden absolute right-0 top-full mt-2 bg-warm-white border border-taupe/25 rounded-2xl shadow-xl overflow-hidden min-w-[150px] z-50" style="box-shadow:0 12px 40px rgba(139,115,85,0.18);">
            {LANGS.map(x => (
              <a href={langUrl(x.c)} role="option" aria-label={x.full} aria-current={x.c === lang ? 'page' : undefined} class={`lang-btn w-full flex items-center justify-between px-4 py-3 font-outfit text-sm transition-colors ${x.c === lang ? 'bg-surface text-espresso' : 'text-espresso/70 hover:bg-surface hover:text-espresso'}`}>
                <span class="font-medium">{x.full}</span>
                <span class="text-xs text-espresso/35 font-mono">{x.l}</span>
              </a>
            ))}
          </div>
        </div>
        <!-- CTA -->
        <a href={SITE.paymentUrl ?? 'https://gumroad.com/l/bentocake'} target="_blank" rel="noopener noreferrer" data-buy-source="header"
           class="flex items-center gap-1.5 bg-mocha text-warm-white font-outfit font-semibold text-[11.5px] lg:text-[13px] px-3 lg:px-5 py-2 lg:py-2.5 rounded-full hover:bg-mocha-dark transition-colors whitespace-nowrap">
          {tr.nav_buy}
        </a>
        <!-- Mobile burger menu -->
        <button id="mobile-menu-btn" type="button" aria-controls="mobile-menu" aria-expanded="false" class="md:hidden w-9 h-9 rounded-full flex items-center justify-center text-espresso hover:bg-taupe/15 transition-colors flex-shrink-0" aria-label="Menu">
          <svg width="18" height="13" viewBox="0 0 20 14" fill="none">
            <path d="M1 1h18M1 7h18M1 13h18" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/>
          </svg>
        </button>
      </div>
    </div>

    <!-- Mobile menu dropdown -->
    <div id="mobile-menu" role="menu" aria-label="Main menu" class="hidden md:hidden absolute top-full left-0 right-0 bg-warm-white border-b border-taupe/20" style="box-shadow:0 12px 32px rgba(139,115,85,0.15);">
      <div class="px-6 py-4 flex flex-col gap-1">
        <a href="#recipes" class="font-outfit font-semibold text-[13px] tracking-[0.14em] uppercase text-espresso/70 hover:text-espresso py-3 border-b border-taupe/10 transition-colors mobile-menu-link">{tr.nav_recipes}</a>
        <a href="#about" class="font-outfit font-semibold text-[13px] tracking-[0.14em] uppercase text-espresso/70 hover:text-espresso py-3 border-b border-taupe/10 transition-colors mobile-menu-link">{tr.nav_author}</a>
        <a href="#price" class="font-outfit font-semibold text-[13px] tracking-[0.14em] uppercase text-espresso/70 hover:text-espresso py-3 border-b border-taupe/10 transition-colors mobile-menu-link">{tr.nav_price}</a>
        <a href="#faq" class="font-outfit font-semibold text-[13px] tracking-[0.14em] uppercase text-espresso/70 hover:text-espresso py-3 border-b border-taupe/10 last:border-b-0 transition-colors mobile-menu-link">FAQ</a>
        <!-- Language switcher in mobile menu -->
        <div class="pt-3 mt-2 flex gap-2">
          {LANGS.map(x => (
            <a href={langUrl(x.c)} aria-current={x.c === lang ? 'page' : undefined} class={`lang-btn flex-1 text-center font-outfit font-semibold text-[11px] tracking-[0.12em] uppercase transition-colors py-2 rounded-full border ${x.c === lang ? 'bg-surface text-espresso border-taupe/60' : 'text-espresso/55 hover:text-espresso border-taupe/30'}`}>{x.l}</a>
          ))}
        </div>
      </div>
    </div>
  </header>

  <!-- ── HERO ── -->
  <section class="min-h-[100dvh] lg:min-h-[85vh] pt-[68px]">
    <div class="max-w-[1440px] mx-auto lg:px-16 flex flex-col-reverse lg:flex-row min-h-[calc(100dvh-68px)] lg:min-h-[calc(85vh-68px)]">

    <!-- Left: text -->
    <div class="flex-1 flex flex-col justify-center px-6 lg:px-0 lg:pr-10 py-8 lg:py-0 w-full lg:max-w-[520px]">

      <!-- Eyebrow + heart (desktop only — on mobile shown over photo) -->
      <div class="animate-fade-up mb-7 hidden lg:block">
        <div class="flex items-center gap-3 mb-3">
          <p class="font-outfit text-[11px] font-semibold tracking-[0.18em] uppercase text-espresso/55">
            {tr.hero_by}
          </p>
        </div>
        <div class="flex items-center gap-2">
          <div class="h-px w-10 bg-mocha/40"></div>
          <svg width="12" height="11" viewBox="0 0 13 12" fill="none">
            <path d="M6.5 11C6.5 11 1 7.3 1 3.8C1 2.3 2.2 1 3.8 1C4.8 1 5.7 1.5 6.2 2.3C6.3 2.5 6.7 2.5 6.8 2.3C7.3 1.5 8.2 1 9.2 1C10.8 1 12 2.3 12 3.8C12 7.3 6.5 11 6.5 11Z" stroke="#8B7355" stroke-width="1.4" stroke-linejoin="round" fill="none"/>
          </svg>
        </div>
      </div>

      <!-- Main heading (desktop only — on mobile shown over photo) -->
      <h1 class="animate-fade-up animate-fade-up-d1 font-cabinet text-espresso leading-[0.92] mb-6 hidden lg:block" style="font-size:clamp(3.8rem,9.5vw,8.5rem);">
        BENTO<br/>CAKE
      </h1>

      <!-- Sub (desktop only — on mobile shown over photo) -->
      <p class="animate-fade-up animate-fade-up-d2 font-outfit text-espresso/65 leading-relaxed mb-8 max-w-[440px] hidden lg:block" style="font-size:clamp(0.95rem,1.2vw,1.1rem);">
        {tr.hero_sub}
      </p>

      <!-- Feature chips -->
      <div class="animate-fade-up animate-fade-up-d2 grid grid-cols-3 lg:flex lg:flex-wrap gap-2 lg:gap-2.5 mb-7 lg:mb-9">
        <div class="flex items-center justify-start gap-2 bg-warm-white border border-taupe/30 rounded-xl px-2.5 lg:px-4 py-2 lg:py-2.5 shadow-sm">
          <svg width="14" height="14" viewBox="0 0 16 16" fill="none" class="flex-shrink-0 lg:w-4 lg:h-4">
            <rect x="2" y="1" width="10" height="13" rx="2" stroke="#8B7355" stroke-width="1.4"/>
            <path d="M5 5h5M5 8h5M5 11h3" stroke="#8B7355" stroke-width="1.3" stroke-linecap="round"/>
          </svg>
          <span class="font-outfit text-[11px] lg:text-sm font-medium text-espresso/75 text-left leading-tight">{tr.hero_chip1}</span>
        </div>
        <div class="flex items-center justify-start gap-2 bg-warm-white border border-taupe/30 rounded-xl px-2.5 lg:px-4 py-2 lg:py-2.5 shadow-sm">
          <svg width="14" height="14" viewBox="0 0 16 16" fill="none" class="flex-shrink-0 lg:w-4 lg:h-4">
            <rect x="1" y="1" width="14" height="14" rx="3" stroke="#8B7355" stroke-width="1.4"/>
            <circle cx="5.5" cy="5.5" r="1.5" stroke="#8B7355" stroke-width="1.2"/>
            <path d="M1 11l4-3 3 2.5 2.5-2 4.5 3.5" stroke="#8B7355" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
          <span class="font-outfit text-[11px] lg:text-sm font-medium text-espresso/75 text-left leading-tight">{tr.hero_chip2}</span>
        </div>
        <div class="flex items-center justify-start gap-2 bg-warm-white border border-taupe/30 rounded-xl px-2.5 lg:px-4 py-2 lg:py-2.5 shadow-sm">
          <svg width="14" height="14" viewBox="0 0 16 16" fill="none" class="flex-shrink-0 lg:w-4 lg:h-4">
            <rect x="1" y="1" width="14" height="14" rx="2.5" stroke="#8B7355" stroke-width="1.4"/>
            <path d="M1 5.5h14M1 10h14M5.5 1v14" stroke="#8B7355" stroke-width="1.2"/>
          </svg>
          <span class="font-outfit text-[11px] lg:text-sm font-medium text-espresso/75 text-left leading-tight">{tr.hero_chip3}</span>
        </div>
      </div>

      <!-- CTA buttons -->
      <div class="animate-fade-up animate-fade-up-d3 flex flex-col lg:flex-row gap-3 items-stretch lg:items-start mb-3.5 lg:mb-10">
        <a href={SITE.paymentUrl ?? 'https://gumroad.com/l/bentocake'} target="_blank" rel="noopener noreferrer" data-buy-source="hero"
           class="btn-pulse flex items-center justify-center gap-3 bg-mocha text-warm-white font-outfit font-semibold text-base px-7 py-2.5 lg:py-4 rounded-xl hover:bg-mocha-dark transition-colors shadow-md">
          <svg width="18" height="18" viewBox="0 0 18 18" fill="none" class="flex-shrink-0">
            <path d="M9 1v10M5 8l4 4 4-4" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
            <path d="M2 13v2a1 1 0 001 1h12a1 1 0 001-1v-2" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/>
          </svg>
          {tr.hero_cta}
        </a>
        <a href="#recipes"
           class="font-outfit font-medium text-espresso/60 text-base py-2 lg:py-4 px-2 hover:text-mocha transition-colors text-center lg:text-left">
          {tr.hero_link}
        </a>
      </div>

      <!-- Stats row — 3 in a single row -->
      <div class="animate-fade-up animate-fade-up-d4 grid grid-cols-3 gap-2 lg:flex lg:items-center lg:gap-5">
        <a href={SITE.tiktokUrl ?? 'https://tiktok.com/@troublebaba'} target="_blank" rel="noopener noreferrer" class="flex items-center gap-2 lg:gap-2.5 hover:opacity-80 transition-opacity">
          <div class="w-7 h-7 lg:w-8 lg:h-8 rounded-xl bg-espresso/6 flex items-center justify-center flex-shrink-0">
            <svg width="11" height="13" viewBox="0 0 13 15" fill="none" class="lg:w-[13px] lg:h-[15px]">
              <path d="M9.5 0.5C9.7 2.5 10.9 3.9 13 4.1V6.5C11.8 6.4 10.7 5.9 9.9 5.1V10C9.9 12.5 7.9 14.5 5.3 14.5C2.7 14.5 0.7 12.5 0.7 10C0.7 7.4 2.7 5.4 5.3 5.4C5.6 5.4 5.8 5.4 6 5.5V8C5.8 7.9 5.6 7.9 5.3 7.9C4 7.9 2.9 8.9 2.9 10.2C2.9 11.5 4 12.4 5.3 12.4C6.6 12.4 7.7 11.4 7.7 10.1L7.8 0.5H9.5Z" fill="#1A1A1A" fill-opacity="0.45"/>
            </svg>
          </div>
          <div class="min-w-0">
            <div class="font-stat text-espresso text-[15px] lg:text-lg leading-tight">2.2M</div>
            <div class="font-outfit text-[9px] lg:text-[10px] text-espresso/40 uppercase tracking-wide">TikTok</div>
          </div>
        </a>
        <div class="hidden lg:block w-px h-7 bg-taupe/35"></div>
        <a href={SITE.instagramUrl ?? 'https://instagram.com/troublebaba'} target="_blank" rel="noopener noreferrer" class="flex items-center gap-2 lg:gap-2.5 hover:opacity-80 transition-opacity">
          <div class="w-7 h-7 lg:w-8 lg:h-8 rounded-xl bg-espresso/6 flex items-center justify-center flex-shrink-0">
            <svg width="12" height="12" viewBox="0 0 14 14" fill="none" class="lg:w-[14px] lg:h-[14px]">
              <rect x="1" y="1" width="12" height="12" rx="3.5" stroke="#1A1A1A" stroke-opacity="0.45" stroke-width="1.3"/>
              <circle cx="7" cy="7" r="2.8" stroke="#1A1A1A" stroke-opacity="0.45" stroke-width="1.3"/>
              <circle cx="10.5" cy="3.5" r="0.8" fill="#1A1A1A" fill-opacity="0.45"/>
            </svg>
          </div>
          <div class="min-w-0">
            <div class="font-stat text-espresso text-[15px] lg:text-lg leading-tight">64K</div>
            <div class="font-outfit text-[9px] lg:text-[10px] text-espresso/40 uppercase tracking-wide">Instagram</div>
          </div>
        </a>
        <div class="hidden lg:block w-px h-7 bg-taupe/35"></div>
        <a href="#recipes" class="flex items-center gap-2 lg:gap-2.5 hover:opacity-80 transition-opacity">
          <div class="w-7 h-7 lg:w-8 lg:h-8 rounded-xl bg-espresso/6 flex items-center justify-center flex-shrink-0">
            <svg width="10" height="12" viewBox="0 0 12 14" fill="none" class="lg:w-[12px] lg:h-[14px]">
              <rect x="1" y="1" width="8" height="11" rx="1.5" stroke="#1A1A1A" stroke-opacity="0.45" stroke-width="1.3"/>
              <path d="M3 4.5h4M3 7h4M3 9.5h2.5" stroke="#1A1A1A" stroke-opacity="0.45" stroke-width="1.2" stroke-linecap="round"/>
            </svg>
          </div>
          <div class="min-w-0">
            <div class="font-stat text-espresso text-[15px] lg:text-lg leading-tight">10</div>
            <div class="font-outfit text-[9px] lg:text-[10px] text-espresso/40 uppercase tracking-wide">{tr.stat_recipes}</div>
          </div>
        </a>
      </div>

      <!-- Mobile-only: Trust row + payment logos -->
      <div class="lg:hidden flex items-center justify-center gap-3 mt-4 pt-3 border-t border-taupe/25 flex-wrap">
        <div class="flex items-center gap-2 text-espresso/55">
          <svg width="12" height="13" viewBox="0 0 11 13" fill="none"><rect x="1" y="5.5" width="9" height="7" rx="1.6" stroke="currentColor" stroke-width="1.2"/><path d="M3 5.5V3.5a2.5 2.5 0 0 1 5 0v2" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/></svg>
          <span class="font-outfit text-[11px]">{tr.cta_secure}</span>
        </div>
        <div class="flex items-center gap-2">
          <span class="font-outfit font-black text-espresso/45 text-[10px] tracking-[0.06em]" style="color:#1A1F71;">VISA</span>
          <span class="flex items-center">
            <span class="inline-block w-3 h-3 rounded-full" style="background:#EB001B;opacity:0.5;"></span>
            <span class="inline-block w-3 h-3 rounded-full -ml-1.5" style="background:#F79E1B;opacity:0.5;"></span>
          </span>
          <span class="flex items-center gap-0.5"><svg width="8" height="10" viewBox="0 0 9 11" fill="#1A1A1A"><path d="M7.3 5.9c0-.85.39-1.5 1.16-1.97-.43-.62-1.08-.96-1.94-1.02-.81-.06-1.7.48-2.02.48-.34 0-1.12-.46-1.74-.46-1.3.02-2.69 1.02-2.69 3.04 0 .6.11 1.22.33 1.86.29.85 1.34 2.94 2.43 2.91.57-.01.97-.4 1.71-.4.72 0 1.09.4 1.72.4 1.1-.02 2.05-1.92 2.33-2.77-1.49-.7-1.29-2.06-1.29-2.07Z"/></svg><span class="font-outfit font-semibold text-[9px] text-espresso/55">Pay</span></span>
          <span class="flex items-center gap-0.5"><span class="font-outfit font-semibold text-[10px] text-espresso/55">G</span><span class="font-outfit font-semibold text-[9px] text-espresso/55">Pay</span></span>
        </div>
      </div>

    </div>

    <!-- Right: image + floating cards -->
    <div class="lg:flex-1 w-full h-[51vh] sm:h-[48vh] lg:h-auto relative overflow-hidden">
      <div class="img-skeleton absolute inset-0 w-full h-full" style="background:linear-gradient(160deg,#D4C4B0 0%,#A8896A 60%,#7A6048 100%);">
        <div class="absolute inset-0 flex flex-col items-center justify-center gap-2 pointer-events-none">
          <svg width="40" height="40" viewBox="0 0 28 28" fill="none" class="opacity-50"><rect x="3" y="7" width="22" height="17" rx="3" stroke="#FDFAF6" stroke-width="1.3"/><circle cx="10" cy="14" r="3" stroke="#FDFAF6" stroke-width="1.3"/><path d="M3 19l5-4 4 4 4-5 6 6" stroke="#FDFAF6" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/><path d="M9 7V5a5 5 0 0 1 10 0v2" stroke="#FDFAF6" stroke-width="1.3" stroke-linecap="round"/></svg>
          <span class="font-mono text-xs tracking-wider" style="color:rgba(253,250,246,0.55);">1200 × 1500 px</span>
        </div>
      </div>
      <img
        src="images/hero-cake.webp"
        alt={tr.hero_img_alt}
        width="1254"
        height="1254"
        fetchpriority="high"
        loading="eager"
        decoding="async"
        class="absolute inset-0 w-full h-full object-cover"
        onload="this.previousElementSibling.style.display='none'"
        onerror="this.style.display='none'"
      />
      <div class="absolute inset-y-0 left-0 w-16 bg-gradient-to-r from-cream/40 to-transparent lg:block hidden pointer-events-none"></div>

      <!-- Mobile-only overlay -->
      <div class="lg:hidden absolute inset-0 z-10 pointer-events-none">
        <div class="absolute inset-0" style="background:linear-gradient(180deg, rgba(0,0,0,0.10) 0%, transparent 25%, transparent 38%, rgba(0,0,0,0.50) 60%, rgba(0,0,0,0.80) 85%, rgba(0,0,0,0.92) 100%);"></div>
        <div class="absolute inset-0" style="background:radial-gradient(ellipse 95% 75% at 50% 35%, transparent 0%, rgba(0,0,0,0.18) 100%);"></div>

        <div class="absolute left-0 right-6 px-6 -translate-y-1/2" style="top:calc(55% - 55px);">
          <p class="font-outfit text-[10px] font-semibold tracking-[0.2em] uppercase text-warm-white mb-3 leading-relaxed whitespace-pre-line" style="text-shadow:0 2px 10px rgba(0,0,0,0.5);" set:html={(tr.hero_by_m ?? '').replace(/\n/g, '<br/>')}></p>
          <div class="flex items-center gap-2">
            <div class="h-px w-10 bg-warm-white/60"></div>
            <svg width="12" height="11" viewBox="0 0 13 12" fill="none">
              <path d="M6.5 11C6.5 11 1 7.3 1 3.8C1 2.3 2.2 1 3.8 1C4.8 1 5.7 1.5 6.2 2.3C6.3 2.5 6.7 2.5 6.8 2.3C7.3 1.5 8.2 1 9.2 1C10.8 1 12 2.3 12 3.8C12 7.3 6.5 11 6.5 11Z" stroke="#FDFAF6" stroke-width="1.4" stroke-linejoin="round" fill="none"/>
            </svg>
          </div>
        </div>

        <div class="absolute inset-x-0 bottom-0 px-6 pb-6">
          {/* Visually duplicates the desktop H1 for mobile viewports;
              kept as <div> for SEO so the page has exactly one <h1>. */}
          <div class="font-cabinet text-warm-white leading-[0.92] mb-4" style="font-size:clamp(3.8rem,17vw,5.6rem);text-shadow:0 4px 24px rgba(0,0,0,0.55);" aria-hidden="true">
            BENTO<br/>CAKE
          </div>
          <p class="font-outfit text-warm-white/90 text-[9px] leading-relaxed max-w-[216px]" style="text-shadow:0 2px 12px rgba(0,0,0,0.5);">
            {tr.hero_sub}
          </p>
        </div>
      </div>

      <!-- Floating card -->
      <div class="hidden lg:block absolute bottom-10 right-8 lg:bottom-14 lg:right-10 bg-warm-white rounded-2xl px-5 py-4 max-w-[280px] z-10" style="box-shadow:0 12px 40px rgba(26,26,26,0.22);">
        <div class="flex items-start gap-3 mb-2">
          <div class="w-12 h-14 rounded-lg bg-mocha flex-shrink-0 flex flex-col items-center justify-center gap-0.5 overflow-hidden">
            <div class="font-cabinet text-warm-white text-[8px] leading-tight tracking-wide">BENTO</div>
            <div class="font-cabinet text-warm-white text-[8px] leading-tight tracking-wide">CAKE</div>
            <div class="w-5 h-px bg-warm-white/30 mt-1"></div>
