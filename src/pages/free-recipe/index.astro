---
import Layout from '../../layouts/Layout.astro';
import FreeRecipe from '../../components/FreeRecipe.astro';
import { t } from '../../i18n/translations.js';

const lang = 'uk' as const;
const tr = (t as any)[lang];
---
<Layout
  title={tr.fr_meta_title}
  description={tr.fr_meta_desc}
  lang={lang}
  path="free-recipe"
  pageType="content"
>
  <FreeRecipe lang={lang} />
</Layout>
