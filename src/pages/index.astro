---
// Root URL — Ukrainian home page (no /uk/ prefix, since UK is the primary audience).
import Layout from '../layouts/Layout.astro';
import HomePage from '../components/HomePage.astro';
import { meta } from '../i18n/translations.js';

const lang = 'uk' as const;
const m = (meta as any)[lang] ?? {};
---
<Layout
  title={m.title}
  description={m.description}
  lang={lang}
  path=""
  pageType="home"
>
  <HomePage lang={lang} />
</Layout>
