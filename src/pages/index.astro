<script>
import { t, langNames, detectBrowserLang, countryToLang, meta, SITE_URL } from '../i18n/translations.js';

const SUPPORTED = ['uk', 'ru', 'pl', 'en'] as const;
type Lang = typeof SUPPORTED[number];
const DEFAULT_LANG: Lang = 'uk';

function isLang(l: string): l is Lang {
  return (SUPPORTED as readonly string[]).includes(l);
}

function applyMeta(lang: Lang) {
  const m = (meta as Record<string, { title: string; description: string; locale: string; htmlLang: string }>)[lang];
  if (!m) return;
  const url = lang === 'uk' ? SITE_URL : `${SITE_URL}/?lang=${lang}`;
  // <html lang>
  document.documentElement.lang = m.htmlLang;
  // <title>
  document.title = m.title;
  // Meta tags
  const setMeta = (id: string, value: string) => {
    const el = document.getElementById(id) as HTMLMetaElement | HTMLLinkElement | null;
    if (!el) return;
    if (el.tagName === 'LINK') (el as HTMLLinkElement).href = value;
    else (el as HTMLMetaElement).content = value;
  };
  setMeta('meta-description', m.description);
  setMeta('canonical-link', url);
  setMeta('og-title', m.title);
  setMeta('og-description', m.description);
  setMeta('og-url', url);
  setMeta('og-locale', m.locale);
  setMeta('tw-title', m.title);
  setMeta('tw-description', m.description);
}

function applyLang(lang: Lang) {
  applyMeta(lang);
  const tr = t[lang];
  if (!tr) return;

  // Simple text nodes
  document.querySelectorAll('[data-i18n]').forEach(el => {
    const key = (el as HTMLElement).dataset.i18n as string;
    if (key && key in tr) {
      const val = (tr as Record<string, unknown>)[key] as string;
      if (typeof val === 'string') {
        // For footer_desc, preserve line breaks
        if (key === 'footer_desc') {
          el.innerHTML = val.replace(/\n/g, '<br/>');
        } else if (key === 'author_title') {
          el.innerHTML = val.replace(/\n/g, '<br/>');
        } else {
          el.textContent = val;
        }
      }
    }
  });

  // Placeholder on email input
  document.querySelectorAll('[data-i18n-ph]').forEach(el => {
    const key = (el as HTMLElement).dataset.i18nPh as string;
    if (key && key in tr) {
      (el as HTMLInputElement).placeholder = (tr as Record<string, unknown>)[key] as string;
    }
  });

  // Rebuild inside-items
  const insideItems = (tr as Record<string, unknown>).inside_items as [string, string][] | undefined;
  if (insideItems) {
    document.querySelectorAll('[data-inside-item]').forEach((el, i) => {
      const item = insideItems[i];
      if (!item) return;
      const titleEl = el.querySelector('[data-inside-title]');
      const descEl = el.querySelector('[data-inside-desc]');
      if (titleEl) titleEl.textContent = item[0];
      if (descEl) descEl.textContent = item[1];
    });
  }

  // Rebuild who-items
  const whoItems = (tr as Record<string, unknown>).who_items as { title: string; text: string }[] | undefined;
  if (whoItems) {
    document.querySelectorAll('[data-who-item]').forEach((el, i) => {
      const item = whoItems[i];
      if (!item) return;
      const titleEl = el.querySelector('[data-who-title]');
      const textEl = el.querySelector('[data-who-text]');
      if (titleEl) titleEl.textContent = item.title;
      if (textEl) textEl.textContent = item.text;
    });
  }

  // Rebuild price-items
  const priceItems = (tr as Record<string, unknown>).price_items as string[] | undefined;
  const priceList = document.getElementById('price-items');
  if (priceList && priceItems) {
    priceList.innerHTML = priceItems.map(item => `
      <li class="flex items-start gap-3 font-outfit text-espresso/70 text-[0.9rem]">
        <svg class="w-[18px] h-[18px] flex-shrink-0 mt-[1px]" viewBox="0 0 18 18" fill="none">
          <circle cx="9" cy="9" r="8" stroke="#8B7355" stroke-width="1.3"/>
          <path d="M5.5 9l2.5 2.5 4.5-4.5" stroke="#8B7355" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
        ${item}
      </li>
    `).join('');
  }

  // Rebuild FAQ — preserve open states first
  const faqItems = (tr as Record<string, unknown>).faq_items as { q: string; a: string }[] | undefined;
  const faqList = document.getElementById('faq-list');
  if (faqList && faqItems) {
    const openSet = new Set<string>();
    faqList.querySelectorAll('.faq-item.open').forEach(el => {
      const idx = (el as HTMLElement).dataset.index;
      if (idx) openSet.add(idx);
    });
    if (openSet.size === 0) openSet.add('0');
    faqList.innerHTML = faqItems.map((faq, i) => `
      <div class="faq-item ${openSet.has(String(i)) ? 'open' : ''} cursor-pointer ${i > 0 ? 'border-t border-taupe/15' : ''}" data-index="${i}">
        <div class="flex items-center gap-6 px-8 py-7">
          <span class="font-outfit text-[11px] font-bold text-mocha/45 tracking-[0.2em] flex-shrink-0 w-7">${String(i + 1).padStart(2, '0')}</span>
          <h3 class="font-outfit font-bold text-espresso text-[1rem] flex-1 leading-snug">${faq.q}</h3>
          <span class="faq-icon w-9 h-9 rounded-full border border-taupe/30 flex items-center justify-center flex-shrink-0 select-none"></span>
        </div>
        <div class="faq-content">
          <div class="mx-8 mb-7 px-6 py-5 rounded-2xl" style="background:#EFE6DA;">
            <p class="font-outfit text-espresso/65 text-[0.9rem] leading-relaxed whitespace-pre-line">${faq.a}</p>
          </div>
        </div>
      </div>
    `).join('');
    attachFaqListeners();
  }

  // Update dropdown label + active state
  const labelMap: Record<string, string> = { uk: 'УКР', ru: 'РУС', pl: 'POL', en: 'ENG' };
  const labelEl = document.getElementById('lang-label');
  if (labelEl) labelEl.textContent = labelMap[lang] || lang.toUpperCase();

  document.querySelectorAll('.lang-btn').forEach(btn => {
    const bl = (btn as HTMLElement).dataset.lang;
    btn.classList.toggle('bg-surface', bl === lang);
    btn.classList.toggle('text-espresso', bl === lang);
  });
}

function attachFaqListeners() {
  document.querySelectorAll('.faq-item').forEach(item => {
    item.addEventListener('click', () => {
      const isOpen = item.classList.contains('open');
      document.querySelectorAll('.faq-item').forEach(i => i.classList.remove('open'));
      if (!isOpen) item.classList.add('open');
    });
  });
}

function showPopup(detectedLang: Lang) {
  const currentLang = (localStorage.getItem('lang') as Lang) || DEFAULT_LANG;
  if (detectedLang === currentLang) return;

  const tr = t[currentLang];
  const popupEl = document.getElementById('lang-popup');
  const msgEl = document.getElementById('popup-msg');
  const switchBtn = document.getElementById('popup-switch');
  const stayBtn = document.getElementById('popup-stay');
  if (!popupEl || !msgEl || !switchBtn || !stayBtn) return;

  const msg = ((tr as Record<string, unknown>).popup_msg as string)
    .replace('%lang%', langNames[detectedLang]);
  msgEl.textContent = msg;
  switchBtn.textContent = (tr as Record<string, unknown>).popup_switch as string;
  stayBtn.textContent = (tr as Record<string, unknown>).popup_stay as string;
  popupEl.classList.remove('hidden');

  switchBtn.addEventListener('click', () => {
    localStorage.setItem('lang', detectedLang);
    applyLang(detectedLang);
    popupEl.classList.add('hidden');
  }, { once: true });

  stayBtn.addEventListener('click', () => {
    popupEl.classList.add('hidden');
  }, { once: true });
}

async function initI18n() {
  // 1. Saved preference
  const saved = localStorage.getItem('lang');
  if (saved && isLang(saved)) {
    applyLang(saved);
    return;
  }

  // 2. Browser language
  const browserLang = detectBrowserLang();

  // 3. IP geolocation fallback
  let ipLang: Lang | null = null;
  if (!browserLang) {
    try {
      const res = await fetch('https://ipapi.co/json/', { signal: AbortSignal.timeout(3000) });
      const data = await res.json();
      const mapped = countryToLang(data.country_code);
      if (isLang(mapped)) ipLang = mapped;
    } catch {
      // silently fall through to default
    }
  }

  const detectedLang: Lang = (browserLang && isLang(browserLang) ? browserLang : null)
    || ipLang
    || DEFAULT_LANG;

  applyLang(detectedLang);

  // Show popup if detected lang differs from default
  if (detectedLang !== DEFAULT_LANG) {
    showPopup(detectedLang);
  }
}

// Scroll reveal
const observer = new IntersectionObserver(entries => {
  entries.forEach(el => {
    if (el.isIntersecting) {
      el.target.classList.add('visible');
      observer.unobserve(el.target);
    }
  });
}, { threshold: 0.1 });
document.querySelectorAll('.reveal').forEach(el => observer.observe(el));

// FAQ accordion (initial attach)
attachFaqListeners();

// Lead form
const form = document.getElementById('lead-form');
const successMsg = document.getElementById('form-success');
if (form && successMsg) {
  form.addEventListener('submit', e => {
    e.preventDefault();
    const email = (document.getElementById('lead-email') as HTMLInputElement)?.value;
    console.log('Lead:', email);
    (form as HTMLFormElement).style.display = 'none';
    successMsg.classList.remove('hidden');
  });
}

// Mobile menu toggle
const mobMenuBtn = document.getElementById('mobile-menu-btn');
const mobMenu = document.getElementById('mobile-menu');
if (mobMenuBtn && mobMenu) {
  mobMenuBtn.addEventListener('click', (e) => {
    e.stopPropagation();
    mobMenu.classList.toggle('hidden');
  });
  document.querySelectorAll('.mobile-menu-link').forEach(link => {
    link.addEventListener('click', () => mobMenu.classList.add('hidden'));
  });
  document.addEventListener('click', (e) => {
    if (!mobMenu.contains(e.target as Node) && !mobMenuBtn.contains(e.target as Node)) {
      mobMenu.classList.add('hidden');
    }
  });
}

// Lang dropdown toggle
const dropBtn = document.getElementById('lang-dropdown-btn');
const dropMenu = document.getElementById('lang-menu');
const dropChevron = document.getElementById('lang-chevron');
if (dropBtn && dropMenu) {
  dropBtn.addEventListener('click', (e) => {
    e.stopPropagation();
    const open = !dropMenu.classList.contains('hidden');
    dropMenu.classList.toggle('hidden', open);
    dropChevron?.style.setProperty('transform', open ? '' : 'rotate(180deg)');
  });
  document.addEventListener('click', () => {
    dropMenu.classList.add('hidden');
    dropChevron?.style.setProperty('transform', '');
  });
}

// Lang switcher buttons
document.querySelectorAll('.lang-btn').forEach(btn => {
  btn.addEventListener('click', () => {
    const lang = (btn as HTMLElement).dataset.lang;
    if (lang && isLang(lang)) {
      localStorage.setItem('lang', lang);
      applyLang(lang);
      // Update dropdown label
      const label = (btn as HTMLElement).dataset.label;
      const labelEl = document.getElementById('lang-label');
      if (labelEl && label) labelEl.textContent = label;
      dropMenu?.classList.add('hidden');
      dropChevron?.style.setProperty('transform', '');
    }
  });
});

// Marquee
const marquee = document.querySelector('.animate-marquee') as HTMLElement | null;
if (marquee) {
  const clone = marquee.cloneNode(true) as HTMLElement;
  marquee.parentElement?.appendChild(clone);
  let x = 0;
  function tick() {
    x -= 1.5;
    const half = marquee!.scrollWidth;
    if (Math.abs(x) >= half) x = 0;
    const parent = marquee!.parentElement;
    if (parent) parent.style.transform = `translateX(${x}px)`;
    requestAnimationFrame(tick);
  }
  requestAnimationFrame(tick);
}

// Init
initI18n();
</script>
