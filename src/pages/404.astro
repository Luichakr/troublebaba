---
import Layout from '../layouts/Layout.astro';
const BASE = import.meta.env.BASE_URL;
---
<Layout
  title="404 — Сторінка не знайдена | TROUBLEBABA"
  description="Сторінка не знайдена."
  path=""
  pageType="error"
  noindex={true}
>
  <main class="min-h-[100dvh] flex items-center justify-center px-6" style="background:#F5EFE8;">
    <div class="text-center max-w-md">
      <!-- Logo -->
      <a href={BASE} class="inline-block font-cabinet text-espresso text-3xl mb-12 tracking-tight" aria-label="TROUBLEBABA — на головну">TROUBLEBABA</a>

      <!-- 404 -->
      <div class="font-cabinet text-mocha mb-6" style="font-size:clamp(5rem,12vw,9rem);line-height:1;">404</div>

      <!-- Decorative line + heart -->
      <div class="flex items-center justify-center gap-3 mb-8" aria-hidden="true">
        <div class="h-px w-16 bg-mocha/40"></div>
        <svg width="14" height="13" viewBox="0 0 13 12" fill="none">
          <path d="M6.5 11C6.5 11 1 7.3 1 3.8C1 2.3 2.2 1 3.8 1C4.8 1 5.7 1.5 6.2 2.3C6.3 2.5 6.7 2.5 6.8 2.3C7.3 1.5 8.2 1 9.2 1C10.8 1 12 2.3 12 3.8C12 7.3 6.5 11 6.5 11Z" stroke="#8B7355" stroke-width="1.3" stroke-linejoin="round" fill="none"/>
        </svg>
        <div class="h-px w-16 bg-mocha/40"></div>
      </div>

      <h1 class="font-cabinet text-espresso mb-4" style="font-size:clamp(1.8rem,3.5vw,2.8rem);line-height:1.1;" data-i18n="p404_heading">
        Сторінка не знайдена
      </h1>
      <p class="font-outfit text-espresso/55 leading-relaxed mb-10" data-i18n="p404_text">
        Здається, такої сторінки не існує. Можливо, вона переїхала або була видалена. Повернемось на головну?
      </p>

      <a href={BASE} class="inline-flex items-center gap-3 bg-mocha text-warm-white font-outfit font-semibold text-base px-7 py-4 rounded-2xl hover:bg-mocha-dark transition-colors min-h-[44px]">
        <svg width="16" height="14" viewBox="0 0 16 14" fill="none" aria-hidden="true">
          <path d="M14 7H2M7 2L2 7l5 5" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
        <span data-i18n="p404_back">На головну</span>
      </a>
    </div>
  </main>

  <script>
    import { initLegalI18n } from '../scripts/legal-i18n.ts';
    initLegalI18n({ titleKey: 'p404_meta_title', descKey: 'p404_meta_desc' });
  </script>
</Layout>
