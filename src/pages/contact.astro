---
import Layout from '../layouts/Layout.astro';
import ContactPage from '../components/ContactPage.astro';
import { t } from '../i18n/translations.js';
const lang = 'uk' as const;
const tr = (t as any)[lang];
---
<Layout title={tr.contact_meta_title} description={tr.contact_meta_desc} lang={lang} path="contact" pageType="content">
  <ContactPage lang={lang} homeUrl="/" />
</Layout>
