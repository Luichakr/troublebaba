---
import Layout from '../../../layouts/Layout.astro';
import RecipesHub from '../../../components/RecipesHub.astro';
import { RECIPES_HUB } from '../../../data/flavors.js';

export function getStaticPaths() {
  return [{ params: { lang: 'ru' } }, { params: { lang: 'pl' } }, { params: { lang: 'en' } }];
}
type Lang = 'ru' | 'pl' | 'en';
const { lang } = Astro.params as { lang: Lang };
const hub = (RECIPES_HUB as any)[lang];
---
<Layout title={hub.metaTitle} description={hub.metaDesc} lang={lang} path={`${lang}/recipes`} pageType="content">
  <RecipesHub lang={lang} homeUrl={`/${lang}/`} />
</Layout>
