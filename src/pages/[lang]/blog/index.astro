---
import Layout from '../../../layouts/Layout.astro';
import BlogHub from '../../../components/BlogHub.astro';
import { t } from '../../../i18n/translations.js';

export function getStaticPaths() {
  return [{ params: { lang: 'ru' } }, { params: { lang: 'pl' } }, { params: { lang: 'en' } }, { params: { lang: 'es' } }, { params: { lang: 'de' } }, { params: { lang: 'fr' } }, { params: { lang: 'it' } }, { params: { lang: 'pt' } }];
}
type Lang = 'ru' | 'pl' | 'en';
const { lang } = Astro.params as { lang: Lang };
const tr = (t as any)[lang];
---
<Layout title={tr.blog_meta_title} description={tr.blog_meta_desc} lang={lang} path={`${lang}/blog`} pageType="content">
  <BlogHub lang={lang} homeUrl={`/${lang}/`} />
</Layout>
