---
import Layout from '../../../layouts/Layout.astro';
import FreeRecipe from '../../../components/FreeRecipe.astro';
import { t } from '../../../i18n/translations.js';

export function getStaticPaths() {
  return [{ params: { lang: 'ru' } }, { params: { lang: 'pl' } }, { params: { lang: 'en' } }];
}
type Lang = 'ru' | 'pl' | 'en';
const { lang } = Astro.params as { lang: Lang };
const tr = (t as any)[lang];
---
<Layout
  title={tr.fr_meta_title}
  description={tr.fr_meta_desc}
  lang={lang}
  path={`${lang}/free-recipe`}
  pageType="content"
>
  <FreeRecipe lang={lang} />
</Layout>
