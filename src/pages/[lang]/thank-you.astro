---
import Layout from '../../layouts/Layout.astro';
import CheckoutResultPage from '../../components/CheckoutResultPage.astro';
import { t } from '../../i18n/translations.js';

export function getStaticPaths() {
  return [{ params: { lang: 'ru' } }, { params: { lang: 'pl' } }, { params: { lang: 'en' } }];
}
type Lang = 'ru' | 'pl' | 'en';
const { lang } = Astro.params as { lang: Lang };
const tr = (t as any)[lang];
---
<Layout title={tr.checkout_success_meta_title} description={tr.checkout_success_meta_desc} lang={lang} path={`${lang}/thank-you`} pageType="legal" noindex={true} loadGA={true}>
  <CheckoutResultPage lang={lang} kind="success" homeUrl={`/${lang}/`} />
</Layout>
