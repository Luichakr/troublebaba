---
import Layout from '../../layouts/Layout.astro';
import CheckoutResultPage from '../../components/CheckoutResultPage.astro';
import { t } from '../../i18n/translations.js';

export function getStaticPaths() {
  return [{ params: { lang: 'ru' } }, { params: { lang: 'pl' } }, { params: { lang: 'en' } }, { params: { lang: 'es' } }, { params: { lang: 'de' } }, { params: { lang: 'fr' } }, { params: { lang: 'it' } }, { params: { lang: 'pt' } }];
}
type Lang = 'ru' | 'pl' | 'en';
const { lang } = Astro.params as { lang: Lang };
const tr = (t as any)[lang];
---
<Layout title={tr.checkout_failure_meta_title} description={tr.checkout_failure_meta_desc} lang={lang} path={`${lang}/payment-failed`} pageType="legal" noindex={true}>
  <CheckoutResultPage lang={lang} kind="failure" homeUrl={`/${lang}/`} />
</Layout>
