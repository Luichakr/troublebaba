---
import Layout from '../layouts/Layout.astro';
import AboutPage from '../components/AboutPage.astro';
import { t } from '../i18n/translations.js';
const lang = 'uk' as const;
const tr = (t as any)[lang];
---
<Layout title={tr.about_meta_title} description={tr.about_meta_desc} lang={lang} path="about" pageType="about">
  <AboutPage lang={lang} homeUrl="/" />
</Layout>
