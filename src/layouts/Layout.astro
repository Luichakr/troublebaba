---
import '../styles/global.css';
interface Props {
  title?: string;
  description?: string;
  lang?: string;
}
const {
  title = 'Bento Cake by TROUBLEBABA — 10 рецептів бенто-тортів | PDF',
  description = 'Збірник 10 авторських рецептів бенто-тортів від кондитера @troublebaba. PDF з покроковими фото, точними грамажами та таблицею перерахунку. Усі рецепти перевірені сотнями кондитерів.',
  lang = 'uk'
} = Astro.props;

const SITE_URL = 'https://bentocake.troublebaba.com';
const OG_IMAGE = `${SITE_URL}/images/hero-cake.webp`;
---
<!doctype html>
<html lang={lang}>
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title id="page-title">{title}</title>
  <meta name="description" id="meta-description" content={description} />

  <!-- Canonical & hreflang alternates -->
  <link rel="canonical" id="canonical-link" href={SITE_URL} />
  <link rel="alternate" hreflang="x-default" href={SITE_URL} />
  <link rel="alternate" hreflang="uk" href={`${SITE_URL}/?lang=uk`} />
  <link rel="alternate" hreflang="ru" href={`${SITE_URL}/?lang=ru`} />
  <link rel="alternate" hreflang="pl" href={`${SITE_URL}/?lang=pl`} />
  <link rel="alternate" hreflang="en" href={`${SITE_URL}/?lang=en`} />

  <!-- Open Graph (Facebook, Telegram, WhatsApp, LinkedIn) -->
  <meta property="og:type" content="product" />
  <meta property="og:site_name" content="TROUBLEBABA" />
  <meta property="og:title" id="og-title" content={title} />
  <meta property="og:description" id="og-description" content={description} />
  <meta property="og:url" id="og-url" content={SITE_URL} />
  <meta property="og:image" id="og-image" content={OG_IMAGE} />
  <meta property="og:image:width" content="1200" />
  <meta property="og:image:height" content="1500" />
  <meta property="og:image:alt" content="Bento Cake — PDF збірник рецептів від TROUBLEBABA" />
  <meta property="og:locale" id="og-locale" content="uk_UA" />
  <meta property="og:locale:alternate" content="ru_RU" />
  <meta property="og:locale:alternate" content="pl_PL" />
  <meta property="og:locale:alternate" content="en_US" />

  <!-- Twitter / X Card -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" id="tw-title" content={title} />
  <meta name="twitter:description" id="tw-description" content={description} />
  <meta name="twitter:image" id="tw-image" content={OG_IMAGE} />

  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,500;0,600;0,700;0,800;0,900;1,400;1,500;1,600&family=Cormorant+Garamond:ital,wght@0,400;0,500;0,600;0,700;1,400;1,500&family=Manrope:wght@400;500;600;700&family=Outfit:wght@400;500;600&family=Caveat:wght@500;600;700&display=swap" rel="stylesheet" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

  <!-- Schema.org Product -->
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "Product",
    "name": "Bento Cake — 10 рецептів",
    "description": "PDF збірник 10 перевірених рецептів бенто-тортів від @troublebaba",
    "brand": { "@type": "Brand", "name": "TROUBLEBABA" },
    "image": "/images/hero-cake.webp",
    "offers": {
      "@type": "Offer",
      "price": "20.00",
      "priceCurrency": "USD",
      "availability": "https://schema.org/InStock",
      "url": "https://gumroad.com/l/bentocake"
    }
  }
  </script>
</head>
<body class="grain">
  <slot />
</body>
</html>
