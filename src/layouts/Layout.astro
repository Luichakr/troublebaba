---
import '../styles/global.css';
import { SITE, LOCALES } from '../config/site.js';
import { t } from '../i18n/translations.js';

type Lang = 'uk' | 'ru' | 'pl' | 'en';

interface Props {
  /** Page title (server-rendered per language; no client mutation). */
  title?: string;
  /** Meta description. */
  description?: string;
  /** Page language (uk | ru | pl | en). */
  lang?: Lang;
  /** URL path RELATIVE to the site root. Examples:
   *  ''         → /            (uk home)
   *  'ru'       → /ru/         (ru home)
   *  'privacy'  → /privacy     (uk privacy)
   *  'ru/privacy' → /ru/privacy (ru privacy)
   */
  path?: string;
  /** Page type — drives JSON-LD and GA loading. */
  pageType?: 'home' | 'legal' | 'error' | 'about' | 'content';
  /** When true, add <meta name="robots" content="noindex,nofollow"> (use for 404). */
  noindex?: boolean;
  /** Override GA loading. Default rule: load only on home. Set true to also load on /thank-you so purchase events fire. */
  loadGA?: boolean;
  /** Restrict hreflang alternates to the languages this page actually has
   *  (e.g. a blog post in ru+uk only). Defaults to all supported languages. */
  hreflangLangs?: Array<'uk' | 'ru' | 'pl' | 'en'>;
}

const {
  title       = 'Bento Cake by TROUBLEBABA — 10 рецептів бенто-тортів | PDF',
  description = 'Збірник 10 авторських рецептів бенто-тортів від кондитера @troublebaba. PDF з покроковими фото, точними грамажами та таблицею перерахунку.',
  lang        = SITE.defaultLang as Lang,
  path        = '',
  pageType    = 'home',
  noindex     = false,
  loadGA: loadGAOverride,
  hreflangLangs,
} = Astro.props;

const BASE     = import.meta.env.BASE_URL;
const SITE_URL = SITE.url;

// Helpers ---------------------------------------------------------------
const SUPPORTED: Lang[] = ['uk', 'ru', 'pl', 'en'];

// Build absolute URL: home for lang, with trailing slash. UK home is at root.
function homePathFor(l: Lang): string {
  return l === 'uk' ? '/' : `/${l}/`;
}

// Strip the lang prefix from `path` if it leads. Returns subpath: '' | 'privacy' | 'terms'.
function stripLangPrefix(p: string): string {
  const parts = p.replace(/^\/+/, '').replace(/\/+$/, '').split('/');
  if (parts.length === 0) return '';
  const head = parts[0];
  if ((SUPPORTED as string[]).includes(head)) return parts.slice(1).join('/');
  return parts.join('/');
}

// Localized URL for the SAME logical page in a different language.
function altUrlFor(l: Lang): string {
  const sub = stripLangPrefix(path);
  return SITE_URL + homePathFor(l) + sub;
}

const CANONICAL = SITE_URL + (path
  ? '/' + path.replace(/^\/+/, '').replace(/\/+$/, '') + (pageType === 'home' ? '/' : '')
  : '/');

const OG_IMAGE  = SITE_URL + SITE.ogImage;
const OG_LOCALE = LOCALES[lang]?.og || 'uk_UA';

// Hreflang alternates — emit for home and legal pages (skip 404/error).
const emitHreflang = pageType === 'home' || pageType === 'legal' || pageType === 'about' || pageType === 'content';
// `hreflangLangs` lets a page restrict alternates to the languages it ACTUALLY
// has (e.g. a blog post that exists only in ru+uk). Defaults to all supported.
// Pointing hreflang at non-existent (404) versions is a real SEO error.
const altLangs = (hreflangLangs && hreflangLangs.length ? hreflangLangs : SUPPORTED) as Lang[];
const hreflangEntries = altLangs.map(l => ({ lang: l, url: altUrlFor(l) }));
const xDefaultUrl = altUrlFor(altLangs.includes('uk') ? 'uk' : altLangs[0]);

// JSON-LD helpers -------------------------------------------------------
const tr = (t as Record<string, any>)[lang] || (t as Record<string, any>).uk;

// Localized breadcrumb "Home" label per language.
const HOME_LABEL: Record<Lang, string> = {
  uk: 'Головна',
  ru: 'Главная',
  pl: 'Strona główna',
  en: 'Home',
};
const homeLabel = HOME_LABEL[lang] ?? 'Home';

// Localized Product.category per language.
const PRODUCT_CATEGORY: Record<Lang, string> = {
  uk: 'Цифрова збірка рецептів',
  ru: 'Цифровой сборник рецептов',
  pl: 'Cyfrowy zbiór przepisów',
  en: 'Digital cookbook',
};

// Skip GA on legal/404 pages — avoid noise + reduce JS on low-value pages.
// `loadGA` prop overrides (e.g. /thank-you needs GA so the `purchase` event fires).
const loadGA = (loadGAOverride ?? pageType === 'home') && !!SITE.gaId;
---
<!doctype html>
<html lang={lang}>
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <base href={BASE} />
  <title>{title}</title>
  <meta name="description" content={description} />
  {noindex && <meta name="robots" content="noindex,nofollow" />}
  <meta name="author" content={SITE.name} />
  <meta name="theme-color" content={SITE.themeColor} />
  <!-- Pinterest domain verification (claim) -->
  <meta name="p:domain_verify" content="69f3bb56cc3d7584a7d85ade4c8e523f" />
  <meta name="color-scheme" content="light" />

  <!-- Canonical (per-page) -->
  <link rel="canonical" href={CANONICAL} />

  {emitHreflang && (
    <>
      <link rel="alternate" hreflang="x-default" href={xDefaultUrl} />
      {hreflangEntries.map(e => (
        <link rel="alternate" hreflang={e.lang} href={e.url} />
      ))}
    </>
  )}

  <!-- Open Graph (Facebook, Telegram, WhatsApp, LinkedIn) -->
  <meta property="og:type"             content={pageType === 'home' ? 'product' : 'website'} />
  <meta property="og:site_name"        content={SITE.name} />
  <meta property="og:title"            content={title} />
  <meta property="og:description"      content={description} />
  <meta property="og:url"              content={CANONICAL} />
  <meta property="og:image"            content={OG_IMAGE} />
  <meta property="og:image:secure_url" content={OG_IMAGE} />
  <meta property="og:image:type"       content={SITE.ogImageType} />
  <meta property="og:image:width"      content={String(SITE.ogImageWidth)} />
  <meta property="og:image:height"     content={String(SITE.ogImageHeight)} />
  <meta property="og:image:alt"        content="Bento Cake — PDF збірник рецептів від TROUBLEBABA" />
  <meta property="og:locale"           content={OG_LOCALE} />
  {SUPPORTED.filter(l => l !== lang).map(l => (
    <meta property="og:locale:alternate" content={LOCALES[l].og} />
  ))}

  <!-- Product price meta — picked up by Pinterest, some Telegram clients -->
  {pageType === 'home' && (
    <>
      <meta property="product:price:amount"   content={String(SITE.price)} />
      <meta property="product:price:currency" content={SITE.currency} />
    </>
  )}

  <!-- Twitter / X Card -->
  <meta name="twitter:card"        content="summary_large_image" />
  <meta name="twitter:title"       content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image"       content={OG_IMAGE} />
  <meta name="twitter:image:alt"   content="Bento Cake — PDF збірник рецептів від TROUBLEBABA" />

  <!-- Favicon set -->
  <link rel="icon"             type="image/svg+xml" href="/favicon.svg" />
  <link rel="icon"             type="image/x-icon"  href="/favicon.ico" />
  <link rel="apple-touch-icon" sizes="180x180"      href="/apple-touch-icon.png" />
  <link rel="manifest"         href="/site.webmanifest" />
  <link rel="mask-icon"        href="/favicon.svg" color="#8B7355" />

  <!-- Google Analytics 4 — only on home pages (skip 404 / legal / error to reduce noise) -->
  {loadGA && (
    <>
      <script async src={`https://www.googletagmanager.com/gtag/js?id=${SITE.gaId}`} is:inline></script>
      <script is:inline define:vars={{ gaId: SITE.gaId }}>
        window.dataLayer = window.dataLayer || [];
        function gtag(){dataLayer.push(arguments);}
        gtag('js', new Date());
        gtag('config', gaId, { anonymize_ip: true });
      </script>
    </>
  )}

  <!-- Fonts — only actually-used families and weights.
       Outfit is loaded locally via @fontsource (see global.css), so it's
       intentionally NOT in this Google Fonts URL. -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@600;700;800;900&family=Manrope:wght@400;500;600;700&family=Caveat:wght@600&display=swap" rel="stylesheet" />

  <!-- JSON-LD: Organization (always) -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "Organization",
    "name": SITE.name,
    "url": SITE_URL + '/',
    "logo": SITE_URL + '/favicon.svg',
    "sameAs": [SITE.instagramUrl, SITE.tiktokUrl, SITE.youtubeUrl, SITE.facebookUrl],
    "email": SITE.contactEmail,
  })} />

  <!-- JSON-LD: WebSite (always) -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebSite",
    "name": SITE.productName,
    "url": SITE_URL + '/',
    "inLanguage": SITE.supportedLangs,
  })} />

  {pageType === 'home' && tr?.faq_items && (
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "FAQPage",
      "inLanguage": lang,
      "mainEntity": tr.faq_items.map((it: any) => ({
        "@type": "Question",
        "name": it.q,
        "acceptedAnswer": { "@type": "Answer", "text": it.a },
      })),
    })} />
  )}

  {pageType === 'home' && (
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Product",
      "name": SITE.productName,
      "description": description,
      "inLanguage": lang,
      "brand": { "@type": "Brand", "name": SITE.name },
      "image": OG_IMAGE,
      "category": PRODUCT_CATEGORY[lang] || PRODUCT_CATEGORY.en,
      "sku": "troublebaba-bento-cake-pdf",
      "offers": {
        "@type": "Offer",
        "price": String(SITE.price),
        "priceCurrency": SITE.currency,
        "availability": "https://schema.org/InStock",
        "itemCondition": "https://schema.org/NewCondition",
        "url": SITE.paymentUrl,
        "seller": { "@type": "Organization", "name": SITE.name },
      }
    })} />
  )}

  {pageType === 'home' && (
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": homeLabel, "item": CANONICAL },
      ],
    })} />
  )}

  {(pageType === 'legal' || pageType === 'about' || pageType === 'content') && (
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": homeLabel, "item": SITE_URL + homePathFor(lang) },
        { "@type": "ListItem", "position": 2, "name": title.split(' | ')[0], "item": CANONICAL },
      ],
    })} />
  )}

  {pageType === 'about' && (
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Person",
      "name": "TROUBLEBABA",
      "alternateName": "Zhenya",
      "jobTitle": "Pastry chef",
      "url": CANONICAL,
      "image": SITE_URL + '/images/author.webp',
      "sameAs": [SITE.instagramUrl, SITE.tiktokUrl, SITE.youtubeUrl, SITE.facebookUrl],
      "worksFor": { "@type": "Organization", "name": SITE.name, "url": SITE_URL + '/' },
    })} />
  )}
</head>
<body>
  <slot />
</body>
</html>
