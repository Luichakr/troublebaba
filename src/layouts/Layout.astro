---
import '../styles/global.css';
import { SITE, LOCALES, canonicalFor } from '../config/site.js';
import { t } from '../i18n/translations.js';

interface Props {
  /** Page title — overrides SITE default. Localized titles are also swapped client-side via applyMeta. */
  title?: string;
  /** Meta description. */
  description?: string;
  /** Initial html lang (real lang is set client-side once detected). */
  lang?: string;
  /** Pathname for canonical (no leading slash). '' = home, 'privacy', 'terms'. */
  path?: string;
  /** Page type — 'home', 'legal', 'error'. Drives JSON-LD selection. */
  pageType?: 'home' | 'legal' | 'error';
  /** When true, add <meta name="robots" content="noindex,nofollow"> (use for 404). */
  noindex?: boolean;
}

const {
  title       = 'Bento Cake by TROUBLEBABA — 10 рецептів бенто-тортів | PDF',
  description = 'Збірник 10 авторських рецептів бенто-тортів від кондитера @troublebaba. PDF з покроковими фото, точними грамажами та таблицею перерахунку.',
  lang        = SITE.defaultLang,
  path        = '',
  pageType    = 'home',
  noindex     = false,
} = Astro.props;

const BASE      = import.meta.env.BASE_URL;
const SITE_URL  = SITE.url;
const CANONICAL = canonicalFor(path);
const OG_IMAGE  = SITE_URL + SITE.ogImage;
const OG_LOCALE = LOCALES[lang]?.og || 'uk_UA';

// hreflang alternates — only for home page (legal pages aren't yet route-localized; they switch lang client-side).
const showHreflang = pageType === 'home';
---
<!doctype html>
<html lang={lang}>
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <base href={BASE} />
  <title id="page-title">{title}</title>
  <meta name="description" id="meta-description" content={description} />
  {noindex && <meta name="robots" content="noindex,nofollow" />}
  <meta name="author" content={SITE.name} />
  <meta name="theme-color" content={SITE.themeColor} />
  <meta name="color-scheme" content="light" />

  <!-- Canonical (per-page) -->
  <link rel="canonical" id="canonical-link" href={CANONICAL} />

  {showHreflang && (
    <>
      <link rel="alternate" hreflang="x-default" href={SITE_URL + '/'} />
      <link rel="alternate" hreflang="uk" href={SITE_URL + '/'} />
      <link rel="alternate" hreflang="ru" href={SITE_URL + '/?lang=ru'} />
      <link rel="alternate" hreflang="pl" href={SITE_URL + '/?lang=pl'} />
      <link rel="alternate" hreflang="en" href={SITE_URL + '/?lang=en'} />
    </>
  )}

  <!-- Open Graph (Facebook, Telegram, WhatsApp, LinkedIn) -->
  <meta property="og:type"             content={pageType === 'home' ? 'product' : 'website'} />
  <meta property="og:site_name"        content={SITE.name} />
  <meta property="og:title"            id="og-title"       content={title} />
  <meta property="og:description"      id="og-description" content={description} />
  <meta property="og:url"              id="og-url"         content={CANONICAL} />
  <meta property="og:image"            id="og-image"       content={OG_IMAGE} />
  <meta property="og:image:secure_url" content={OG_IMAGE} />
  <meta property="og:image:type"       content={SITE.ogImageType} />
  <meta property="og:image:width"      content={String(SITE.ogImageWidth)} />
  <meta property="og:image:height"     content={String(SITE.ogImageHeight)} />
  <meta property="og:image:alt"        id="og-image-alt"   content="Bento Cake — PDF збірник рецептів від TROUBLEBABA" />
  <meta property="og:locale"           id="og-locale"      content={OG_LOCALE} />
  <meta property="og:locale:alternate" content="uk_UA" />
  <meta property="og:locale:alternate" content="ru_RU" />
  <meta property="og:locale:alternate" content="pl_PL" />
  <meta property="og:locale:alternate" content="en_US" />

  <!-- Twitter / X Card -->
  <meta name="twitter:card"        content="summary_large_image" />
  <meta name="twitter:title"       id="tw-title"       content={title} />
  <meta name="twitter:description" id="tw-description" content={description} />
  <meta name="twitter:image"       id="tw-image"       content={OG_IMAGE} />
  <meta name="twitter:image:alt"   content="Bento Cake — PDF збірник рецептів від TROUBLEBABA" />

  <!-- Favicon set -->
  <link rel="icon"             type="image/svg+xml" href="/favicon.svg" />
  <link rel="icon"             type="image/x-icon"  href="/favicon.ico" />
  <link rel="apple-touch-icon" sizes="180x180"      href="/apple-touch-icon.png" />
  <link rel="manifest"         href="/site.webmanifest" />
  <link rel="mask-icon"        href="/favicon.svg" color="#8B7355" />

  <!-- Google Analytics 4 — loaded on every page via this shared layout -->
  {SITE.gaId && (
    <>
      <script async src={`https://www.googletagmanager.com/gtag/js?id=${SITE.gaId}`} is:inline></script>
      <script is:inline define:vars={{ gaId: SITE.gaId }}>
        window.dataLayer = window.dataLayer || [];
        function gtag(){dataLayer.push(arguments);}
        gtag('js', new Date());
        gtag('config', gaId, { anonymize_ip: true });
      </script>
    </>
  )}

  <!-- Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,500;0,600;0,700;0,800;0,900;1,400;1,500;1,600&family=Cormorant+Garamond:ital,wght@0,400;0,500;0,600;0,700;1,400;1,500&family=Manrope:wght@400;500;600;700&family=Outfit:wght@400;500;600&family=Caveat:wght@500;600;700&display=swap" rel="stylesheet" />

  <!-- JSON-LD: Organization (always) -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "Organization",
    "name": SITE.name,
    "url": SITE_URL + '/',
    "logo": SITE_URL + '/favicon.svg',
    "sameAs": [SITE.instagramUrl, SITE.tiktokUrl, SITE.youtubeUrl, SITE.facebookUrl],
    "email": SITE.contactEmail,
  })} />

  <!-- JSON-LD: WebSite (always) -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebSite",
    "name": SITE.productName,
    "url": SITE_URL + '/',
    "inLanguage": SITE.supportedLangs,
  })} />

  {pageType === 'home' && t.uk.faq_items && (
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "FAQPage",
      "mainEntity": t.uk.faq_items.map((it) => ({
        "@type": "Question",
        "name": it.q,
        "acceptedAnswer": { "@type": "Answer", "text": it.a },
      })),
    })} />
  )}

  {pageType === 'home' && (
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Product",
      "name": SITE.productName,
      "description": description,
      "brand": { "@type": "Brand", "name": SITE.name },
      "image": OG_IMAGE,
      "category": "Digital download / Cookbook",
      "offers": {
        "@type": "Offer",
        "price": String(SITE.price),
        "priceCurrency": SITE.currency,
        "availability": "https://schema.org/InStock",
        "url": SITE.paymentUrl,
      }
    })} />
  )}

  {pageType === 'legal' && (
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Home", "item": SITE_URL + '/' },
        { "@type": "ListItem", "position": 2, "name": title.split(' | ')[0], "item": CANONICAL },
      ],
    })} />
  )}
</head>
<body>
  <slot />
</body>
</html>
